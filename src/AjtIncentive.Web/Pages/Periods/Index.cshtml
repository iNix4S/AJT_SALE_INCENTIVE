@page
@model AjtIncentive.Web.Pages.Periods.IndexModel
@{
    ViewData["Title"] = "Periods";
}

<div class="content-panel">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
        <div>
            <div class="eyebrow">Setup</div>
            <h1 class="h3 mb-1">Periods</h1>
            <p class="text-muted mb-0">Master data ของรอบคำนวณ ใช้ร่วมทั้ง TC01 และ TC02</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm enterprise-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Period ID</th>
                    <th>Period Code</th>
                    <th>Sales Month</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var p in Model.Periods)
            {
                <tr>
                    <td class="fw-semibold">@p.PeriodId</td>
                    <td>@p.PeriodCode</td>
                    <td>@p.SalesMonth.ToString("yyyy-MM-dd")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>