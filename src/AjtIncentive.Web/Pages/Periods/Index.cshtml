@page
@model AjtIncentive.Web.Pages.Periods.IndexModel
@{
    ViewData["Title"] = "Periods";
}

<section class="content-panel mb-4 calc-header-panel">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <div class="eyebrow">Setup</div>
            <h1 class="h3 mb-1">Periods</h1>
            <p class="text-muted mb-0">Add, edit, close, and delete master periods directly in the database.</p>
        </div>
        <div class="calc-master-pill">Master data: @Model.Periods.Count periods</div>
    </div>
</section>

@if (TempData["Message"] != null)
{
    <div class="alert alert-info mb-4">@TempData["Message"]</div>
}

<section class="row g-4">
    <div class="col-12 col-xl-4">
        <article class="content-panel h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <div class="eyebrow">Master Form</div>
                    <h2 class="h5 mb-0">@(Model.IsEditMode ? "Edit Period" : "Add Period")</h2>
                </div>
            </div>

            <form method="post" asp-page-handler="Save">
                <input type="hidden" asp-for="Input.PeriodId" />

                <div class="mb-3">
                    <label asp-for="Input.PeriodCode" class="form-label">Period Code</label>
                    <input asp-for="Input.PeriodCode" class="form-control" placeholder="e.g. FY2027-04" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.SalesMonth" class="form-label">Sales Month</label>
                    <input asp-for="Input.SalesMonth" type="date" class="form-control" />
                </div>

                <div class="row g-3">
                    <div class="col-6">
                        <label asp-for="Input.YearNo" class="form-label">Year No</label>
                        <input asp-for="Input.YearNo" type="number" class="form-control" />
                    </div>
                    <div class="col-6">
                        <label asp-for="Input.MonthNo" class="form-label">Month No</label>
                        <input asp-for="Input.MonthNo" type="number" min="1" max="12" class="form-control" />
                    </div>
                </div>

                <div class="mt-3 mb-3">
                    <label asp-for="Input.Status" class="form-label">Status</label>
                    <select asp-for="Input.Status" class="form-select">
                        <option value="OPEN">OPEN</option>
                        <option value="CLOSED">CLOSED</option>
                    </select>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Input.IsClosed" class="form-check-input" />
                    <label asp-for="Input.IsClosed" class="form-check-label">Period is closed</label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger flex-grow-1">@(Model.IsEditMode ? "Update Period" : "Add Period")</button>
                    @if (Model.IsEditMode)
                    {
                        <button type="submit" asp-page-handler="CancelEdit" class="btn btn-outline-secondary">Cancel</button>
                    }
                </div>
            </form>
        </article>
    </div>

    <div class="col-12 col-xl-8">
        <article class="content-panel h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <div class="eyebrow">Current Master</div>
                    <h2 class="h5 mb-0">Period List</h2>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-sm enterprise-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Period Code</th>
                            <th>Sales Month</th>
                            <th>Year</th>
                            <th>Month</th>
                            <th>Status</th>
                            <th>Closed</th>
                            <th>Updated</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var p in Model.Periods)
                    {
                        <tr>
                            <td class="fw-semibold">@p.PeriodId</td>
                            <td>@p.PeriodCode</td>
                            <td>@p.SalesMonth.ToString("yyyy-MM-dd")</td>
                            <td>@p.YearNo</td>
                            <td>@p.MonthNo</td>
                            <td>
                                <span class="badge @(p.Status == "OPEN" ? "text-bg-success" : "text-bg-secondary")">@p.Status</span>
                            </td>
                            <td>@(p.IsClosed ? "Yes" : "No")</td>
                            <td>@((p.UpdatedAt ?? p.CreatedAt).ToString("yyyy-MM-dd HH:mm"))</td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-2">
                                    <a asp-page="./Index" asp-route-editId="@p.PeriodId" class="btn btn-sm btn-outline-primary">Edit</a>
                                    <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('Confirm delete period @p.PeriodCode?');">
                                        <input type="hidden" name="periodId" value="@p.PeriodId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </article>
    </div>
</section>
