@page
@model AjtIncentive.Web.Pages.Approvals.IndexModel
@{
    ViewData["Title"] = "Approvals";
}

<div class="content-panel">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
        <div>
            <div class="eyebrow">Workflow</div>
            <h1 class="h3 mb-1">Approvals</h1>
            <p class="text-muted mb-0">Track the latest run status to control the approval process and For HR submission.</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm enterprise-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Calc Run</th>
                    <th>Channel</th>
                    <th>Period</th>
                    <th>Run Status</th>
                    <th>Approved By</th>
                    <th>Updated</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var run in Model.Runs)
            {
                <tr>
                    <td class="fw-semibold">@run.CalcRunId</td>
                    <td>@run.ChannelCode</td>
                    <td>@run.PeriodCode</td>
                    <td>@run.RunStatus</td>
                    <td>@run.ApprovedBy</td>
                    <td>@(run.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>