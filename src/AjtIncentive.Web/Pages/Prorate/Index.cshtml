@page
@model AjtIncentive.Web.Pages.Prorate.IndexModel
@{
    ViewData["Title"] = "Prorate";
}

<section class="adj-header-panel mb-4">
    <p class="adj-eyebrow">Adjustments</p>
    <h1 class="adj-title">Prorate Logic</h1>
    <p class="adj-desc">บันทึก prorate factor สำหรับพนักงานที่เข้า / ออก / โอนย้ายกลางเดือน</p>
</section>

@if (TempData["Message"] is string msg)
{
    var cls = msg.StartsWith("Error") ? "alert-danger" : "alert-success";
    <div class="alert @cls alert-dismissible fade show mb-3" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Filter -->
<div class="content-panel mb-4">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label small fw-semibold">Channel</label>
            <select name="ChannelId" class="form-select form-select-sm" style="min-width:130px;">
                @foreach (var c in Model.Channels)
                {
                    <option value="@c.ChannelId" selected="@(c.ChannelId == Model.ChannelId)">@c.ChannelCode – @c.ChannelNameEn</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label small fw-semibold">Period</label>
            <select name="PeriodId" class="form-select form-select-sm" style="min-width:130px;">
                @foreach (var p in Model.Periods)
                {
                    <option value="@p.PeriodId" selected="@(p.PeriodId == Model.PeriodId)">@p.PeriodCode</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary btn-sm">Load</button>
        </div>
    </form>
</div>

<!-- Prorate Rule Reference -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="content-panel">
            <h6 class="fw-semibold mb-3">กฎ Prorate (3.2)</h6>
            <div class="table-responsive">
                <table class="table table-sm table-bordered mb-0 small">
                    <thead class="table-dark">
                        <tr>
                            <th>กรณี</th>
                            <th>Logic</th>
                            <th>ตัวอย่าง</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="badge bg-success">JOIN</span> พนักงานเข้างานกลางเดือน</td>
                            <td>Prorate = (วันทำงานจริง / วันทำงานในเดือน) × Incentive เต็ม</td>
                            <td>เข้าวันที่ 16 = คำนวณ 50%</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-danger">RESIGN</span> พนักงานลาออกกลางเดือน</td>
                            <td>ระบุว่าจ่ายหรือไม่จ่าย Incentive (Policy decision)</td>
                            <td>ต้องได้รับการยืนยันจาก HR</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-warning text-dark">TRANSFER</span> Transfer ข้าม Region กลางวด</td>
                            <td>แยกคำนวณ Incentive แต่ละ Region ตามสัดส่วนวัน</td>
                            <td>Region A 10 วัน + Region B 20 วัน</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-info text-dark">POSITION_CHANGE</span> เปลี่ยน Position กลางวด</td>
                            <td>ระบุว่าใช้ Position เดิมหรือใหม่ หรือแยกคำนวณ</td>
                            <td>ต้องได้รับการยืนยันจาก HR/Finance</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Existing Records -->
<div class="content-panel mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-semibold mb-0">Prorate Records — @Model.SelectedChannelCode / @Model.SelectedPeriodCode</h6>
        <span class="badge bg-secondary">@Model.ProrateRecords.Count records</span>
    </div>

    @if (Model.ProrateRecords.Count == 0)
    {
        <div class="adj-empty-state">
            <span class="text-muted small">ยังไม่มีข้อมูล Prorate สำหรับ Channel/Period นี้</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Employee</th>
                        <th>Name</th>
                        <th>Type</th>
                        <th class="text-center">Actual Days</th>
                        <th class="text-center">Total Days</th>
                        <th class="text-center">Factor</th>
                        <th>Remarks</th>
                        <th>Approved By</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.ProrateRecords)
                    {
                        var badgeClass = r.ProrateType switch {
                            "JOIN"            => "bg-success",
                            "RESIGN"          => "bg-danger",
                            "TRANSFER"        => "bg-warning text-dark",
                            "POSITION_CHANGE" => "bg-info text-dark",
                            _                 => "bg-secondary"
                        };
                        var factor = r.TotalDays > 0 ? (decimal)r.ActualDays / r.TotalDays : 0m;
                        <tr>
                            <td class="fw-semibold">@r.EmployeeCode</td>
                            <td>@r.EmployeeNameTh</td>
                            <td><span class="badge @badgeClass small">@r.ProrateType</span></td>
                            <td class="text-center">@r.ActualDays</td>
                            <td class="text-center">@r.TotalDays</td>
                            <td class="text-center fw-semibold">@factor.ToString("P0")</td>
                            <td class="text-muted small">@r.Remarks</td>
                            <td class="text-muted small">@r.ApprovedBy</td>
                            <td>
                                <form method="post" asp-page-handler="Delete" class="d-inline">
                                    <input type="hidden" name="ProrateId" value="@r.ProrateId" />
                                    <input type="hidden" name="ChannelId" value="@Model.ChannelId" />
                                    <input type="hidden" name="PeriodId" value="@Model.PeriodId" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-1"
                                            onclick="return confirm('ลบ Prorate record ของ @r.EmployeeCode?')">
                                        ลบ
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Add New Record Form -->
<div class="content-panel">
    <h6 class="fw-semibold mb-3">เพิ่ม Prorate Record</h6>
    <form method="post" asp-page-handler="Save" class="row g-3">
        <input type="hidden" name="ChannelId" value="@Model.ChannelId" />
        <input type="hidden" name="PeriodId" value="@Model.PeriodId" />

        <div class="col-md-3">
            <label class="form-label small fw-semibold">Employee</label>
            <select name="EmployeeCode" class="form-select form-select-sm" required>
                <option value="">-- เลือก Employee --</option>
                @foreach (var e in Model.Employees)
                {
                    <option value="@e.EmployeeCode">@e.EmployeeCode – @e.EmployeeNameTh</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label small fw-semibold">ประเภท</label>
            <select name="ProrateType" class="form-select form-select-sm" required>
                <option value="JOIN">JOIN – เข้างานกลางเดือน</option>
                <option value="RESIGN">RESIGN – ลาออกกลางเดือน</option>
                <option value="TRANSFER">TRANSFER – โอนย้ายข้าม Region</option>
                <option value="POSITION_CHANGE">POSITION_CHANGE – เปลี่ยน Position</option>
            </select>
        </div>

        <div class="col-md-1">
            <label class="form-label small fw-semibold">Actual Days</label>
            <input type="number" name="ActualDays" class="form-control form-control-sm text-center"
                   min="0" max="31" value="11" required />
        </div>

        <div class="col-md-1">
            <label class="form-label small fw-semibold">Total Days</label>
            <input type="number" name="TotalDays" class="form-control form-control-sm text-center"
                   min="1" max="31" value="22" required />
        </div>

        <div class="col-md-2">
            <label class="form-label small fw-semibold">Approved By</label>
            <input type="text" name="ApprovedBy" class="form-control form-control-sm"
                   placeholder="ชื่อผู้อนุมัติ" />
        </div>

        <div class="col-md-2">
            <label class="form-label small fw-semibold">Remarks</label>
            <input type="text" name="Remarks" class="form-control form-control-sm"
                   placeholder="หมายเหตุ" />
        </div>

        <div class="col-md-1 d-flex align-items-end">
            <button type="submit" class="btn btn-primary btn-sm w-100">บันทึก</button>
        </div>
    </form>

    <div class="adj-note mt-3">
        <strong>หมายเหตุ:</strong> Factor = Actual Days / Total Days
        (เช่น 11/22 = 50%) ระบบจะนำ factor นี้ไปคูณกับ Incentive ที่คำนวณได้เต็มเดือน
    </div>
</div>
