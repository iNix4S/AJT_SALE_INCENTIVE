@page
@model AjtIncentive.Web.Pages.Target.IndexModel
@{
    ViewData["Title"] = "Target";
}

<section class="adj-header-panel mb-4">
    <p class="adj-eyebrow">Config</p>
    <h1 class="adj-title">Target Management</h1>
    <p class="adj-desc">กำหนดค่า Target ตามตารางจริง dbo.trn_sales_target (Period + Channel + Salesman + Product)</p>
</section>

@if (TempData["Message"] is string msg)
{
    var cls = msg.StartsWith("Error") ? "alert-danger" : "alert-success";
    <div class="alert @cls alert-dismissible fade show mb-3" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="content-panel mb-4">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Channel</label>
            <select name="ChannelId" class="form-select form-select-sm" required>
                @foreach (var c in Model.Channels)
                {
                    <option value="@c.ChannelId" selected="@(c.ChannelId == Model.ChannelId)">@c.ChannelCode - @c.ChannelNameEn</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Period</label>
            <select name="PeriodId" class="form-select form-select-sm" required>
                @foreach (var p in Model.Periods)
                {
                    <option value="@p.PeriodId" selected="@(p.PeriodId == Model.PeriodId)">@p.PeriodCode</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Keyword</label>
            <input type="text" name="Keyword" value="@Model.Keyword" class="form-control form-control-sm" placeholder="ค้นหา salesman/product" />
        </div>
        <div class="col-md-3">
            <div class="small text-muted mb-1">Selected</div>
            <div class="fw-semibold">@Model.SelectedChannelCode / @Model.SelectedPeriodCode</div>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm">Load</button>
            <a class="btn btn-outline-secondary btn-sm" asp-page="./Index" asp-route-ChannelId="@Model.ChannelId" asp-route-PeriodId="@Model.PeriodId">Clear</a>
        </div>
    </form>
</div>

<div class="content-panel mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-semibold mb-0">Target Rows</h6>
        <span class="badge bg-secondary">@Model.TargetRows.Count rows</span>
    </div>

    @if (Model.TargetRows.Count == 0)
    {
        <div class="adj-empty-state">
            <span class="text-muted small">ไม่พบข้อมูล Target สำหรับเงื่อนไขที่เลือก</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Salesman</th>
                        <th>Product</th>
                        <th class="text-end">Target Amount</th>
                        <th class="text-end">Pct Salesman</th>
                        <th>Approved</th>
                        <th class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in Model.TargetRows)
                {
                    <tr>
                        <td class="text-muted">@r.SalesTargetId</td>
                        <td>
                            <div class="fw-semibold">@r.SalesmanCode</div>
                            <div class="small text-muted">@(string.IsNullOrWhiteSpace(r.EmployeeNameTh) ? "-" : r.EmployeeNameTh)</div>
                        </td>
                        <td>
                            <div class="fw-semibold">@r.ProductCode</div>
                            <div class="small text-muted">@(string.IsNullOrWhiteSpace(r.ProductNameTh) ? "-" : r.ProductNameTh)</div>
                        </td>
                        <td class="text-end fw-semibold">@r.TargetAmount.ToString("N2")</td>
                        <td class="text-end">@(r.PctSalesman.HasValue ? r.PctSalesman.Value.ToString("N4") : "-")</td>
                        <td>
                            <div>@(string.IsNullOrWhiteSpace(r.ApprovedBy) ? "-" : r.ApprovedBy)</div>
                            <div class="small text-muted">@(r.ApprovedAt.HasValue ? r.ApprovedAt.Value.ToString("yyyy-MM-dd HH:mm") : "-")</div>
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm" role="group">
                                <a class="btn btn-outline-primary"
                                   asp-page="./Index"
                                   asp-route-ChannelId="@Model.ChannelId"
                                   asp-route-PeriodId="@Model.PeriodId"
                                   asp-route-Keyword="@Model.Keyword"
                                   asp-route-EditId="@r.SalesTargetId">แก้ไข</a>
                                <form method="post" asp-page-handler="Delete" class="d-inline">
                                    <input type="hidden" name="ChannelId" value="@Model.ChannelId" />
                                    <input type="hidden" name="PeriodId" value="@Model.PeriodId" />
                                    <input type="hidden" name="Keyword" value="@Model.Keyword" />
                                    <input type="hidden" name="SalesTargetId" value="@r.SalesTargetId" />
                                    <button type="submit" class="btn btn-outline-danger" onclick="return confirm('ลบ Target ID @r.SalesTargetId ?')">ลบ</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="content-panel">
    <h6 class="fw-semibold mb-3">@(Model.IsEditMode ? "แก้ไข Target" : "เพิ่ม Target")</h6>
    <form method="post" asp-page-handler="Save" class="row g-3">
        <input type="hidden" name="ChannelId" value="@Model.ChannelId" />
        <input type="hidden" name="PeriodId" value="@Model.PeriodId" />
        <input type="hidden" name="Keyword" value="@Model.Keyword" />
        <input type="hidden" name="SalesTargetId" value="@Model.EditForm.SalesTargetId" />

        <div class="col-md-3">
            <label class="form-label small fw-semibold">Salesman</label>
            <select name="SalesmanCode" class="form-select form-select-sm" required>
                @foreach (var e in Model.Employees)
                {
                    <option value="@e.EmployeeCode" selected="@(e.EmployeeCode == Model.EditForm.SalesmanCode)">@e.EmployeeCode - @e.EmployeeNameTh</option>
                }
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label small fw-semibold">Product</label>
            <select name="ProductCode" class="form-select form-select-sm" required>
                @foreach (var p in Model.Products)
                {
                    <option value="@p.ProductCode" selected="@(p.ProductCode == Model.EditForm.ProductCode)">@p.ProductCode - @p.ProductNameTh</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label small fw-semibold">Target Amount</label>
            <input type="number" name="TargetAmount" class="form-control form-control-sm text-end" step="0.01" min="0" value="@Model.EditForm.TargetAmount" required />
        </div>

        <div class="col-md-2">
            <label class="form-label small fw-semibold">Pct Salesman</label>
            <input type="number" name="PctSalesman" class="form-control form-control-sm text-end" step="0.0001" min="0" value="@Model.EditForm.PctSalesman" />
        </div>

        <div class="col-md-2">
            <label class="form-label small fw-semibold">Approved By</label>
            <input type="text" name="ApprovedBy" class="form-control form-control-sm" value="@Model.EditForm.ApprovedBy" />
        </div>

        <div class="col-md-3">
            <label class="form-label small fw-semibold">Approved At</label>
            <input type="datetime-local" name="ApprovedAt" class="form-control form-control-sm" value="@(Model.EditForm.ApprovedAt.HasValue ? Model.EditForm.ApprovedAt.Value.ToString("yyyy-MM-ddTHH:mm") : string.Empty)" />
        </div>

        <div class="col-md-9 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-primary btn-sm">@(Model.IsEditMode ? "บันทึกการแก้ไข" : "เพิ่ม Target")</button>
            @if (Model.IsEditMode)
            {
                <a class="btn btn-outline-secondary btn-sm"
                   asp-page="./Index"
                   asp-route-ChannelId="@Model.ChannelId"
                   asp-route-PeriodId="@Model.PeriodId"
                   asp-route-Keyword="@Model.Keyword">ยกเลิกการแก้ไข</a>
            }
        </div>
    </form>

    <div class="adj-note mt-3">
        <strong>อ้างอิงฐานข้อมูลจริง:</strong>
        ค่าที่บันทึกลงตาราง <code>dbo.trn_sales_target</code> ตามคีย์หลักเชิงธุรกิจ
        <code>(period_id, channel_id, salesman_code, product_code)</code>
    </div>
</div>