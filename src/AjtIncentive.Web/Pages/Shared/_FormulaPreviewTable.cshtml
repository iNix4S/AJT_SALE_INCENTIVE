@model IReadOnlyList<AjtIncentive.Web.Services.FormulaPreviewRow>

<div class="table-responsive">
    <table class="table table-sm enterprise-table align-middle mb-0">
        <thead>
            <tr>
                <th>Salesman</th>
                <th>Position</th>
                <th>Ws Type</th>
                <th>Product</th>
                <th>Pct</th>
                <th>Base</th>
                <th>Weight</th>
                <th>Incentive Formula</th>
                <th>Incentive</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model)
        {
            <tr>
                <td>@row.SalesmanCode</td>
                <td>@row.PositionCode</td>
                <td>@(row.WsType ?? "-")</td>
                <td>@row.ProductCode</td>
                <td>@row.PctAchievement.ToString("0.0000")</td>
                <td>@row.BaseRate.ToString("0.00")</td>
                <td>@row.WeightPct.ToString("0.000000")</td>
                <td>
                    <div class="fw-semibold">@(row.FormulaCodeIncent ?? "-")</div>
                    <div class="text-muted small"><code>@(row.FormulaExprIncent ?? "-")</code></div>
                </td>
                <td>@row.IncentiveAmount.ToString("0.00")</td>
            </tr>
        }
        </tbody>
    </table>
</div>
