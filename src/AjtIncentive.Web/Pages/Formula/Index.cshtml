@page
@model AjtIncentive.Web.Pages.Formula.IndexModel
@{
    ViewData["Title"] = "Formula Expression";
    var activeCount = Model.Formulas.Count(f => f.IsActive);
}

<section class="content-panel mb-4 mt-modern-hero">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3">
        <div>
            <div class="eyebrow">Config</div>
            <h1 class="h3 mb-2">Formula Expression</h1>
            <p class="mb-0 mt-hero-copy">Define and manage incentive formula expressions evaluated by the NCalc engine.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <span class="mt-kpi-chip">
                <span class="mt-kpi-label">Total</span>
                <span class="mt-kpi-value">@Model.Formulas.Count</span>
            </span>
            <span class="mt-kpi-chip">
                <span class="mt-kpi-label">Active</span>
                <span class="mt-kpi-value">@activeCount</span>
            </span>
            <span class="mt-kpi-chip">
                <span class="mt-kpi-label">Steps</span>
                <span class="mt-kpi-value">@AjtIncentive.Web.Pages.Formula.IndexModel.FormulaSteps.Count</span>
            </span>
        </div>
    </div>
</section>

@if (TempData["Message"] is string msg)
{
    var cls = msg.StartsWith("Error") ? "alert-danger" : "alert-success";
    <div class="alert @cls alert-dismissible fade show mb-3" role="alert">
        @msg <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="content-panel mb-4 mt-modern-card mt-fade-in">
    <div class="eyebrow mb-2">Filter</div>
    <h5 class="h6 fw-semibold mb-3">Search Formula Catalog</h5>
    <form method="get" class="mt-controls-form">
        <div class="mt-controls-shell">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-4 col-xl-3">
                    <label class="form-label small fw-semibold">Channel</label>
                    <select name="FilterChannel" id="filterChannelSelect" class="form-select form-select-sm">
                        <option value="">All</option>
                        <option value="SHARED" selected="@("SHARED" == Model.FilterChannel)">SHARED (no channel)</option>
                        @foreach (var c in Model.Channels)
                        {
                            <option value="@c.ChannelCode" selected="@(c.ChannelCode == Model.FilterChannel)">@c.ChannelCode</option>
                        }
                    </select>
                    <div id="includeSharedWrap" class="form-check mt-2"
                         style="display:@((!string.IsNullOrEmpty(Model.FilterChannel) && Model.FilterChannel != "SHARED") ? "block" : "none")">
                        <input class="form-check-input" type="checkbox" name="FilterIncludeShared"
                               id="chkIncludeShared" value="true"
                               @(Model.FilterIncludeShared ? "checked" : "") />
                        <label class="form-check-label small text-muted" for="chkIncludeShared">
                            Include SHARED formulas
                        </label>
                    </div>
                </div>
                <div class="col-12 col-md-4 col-xl-3">
                    <label class="form-label small fw-semibold">Formula Step</label>
                    <select name="FilterStep" class="form-select form-select-sm">
                        <option value="">All</option>
                        @foreach (var s in AjtIncentive.Web.Pages.Formula.IndexModel.FormulaSteps)
                        {
                            <option value="@s" selected="@(s == Model.FilterStep)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-4 col-xl-4 ms-xl-auto">
                    <div class="d-grid d-md-flex gap-2 justify-content-md-end">
                        <button type="submit" class="btn target-filter-btn target-filter-btn--primary btn-sm">Filter</button>
                        <a class="btn target-filter-btn target-filter-btn--secondary btn-sm" asp-page="./Index">Clear</a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="content-panel mb-4 mt-modern-card mt-fade-in mt-fade-in-delay">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <div class="eyebrow mb-1">Catalog</div>
            <h5 class="h6 fw-semibold mb-0">Formula Expressions</h5>
        </div>
        <span class="mt-kpi-chip">
            <span class="mt-kpi-label">Rows</span>
            <span class="mt-kpi-value">@Model.Formulas.Count</span>
        </span>
    </div>

    @if (Model.Formulas.Count == 0)
    {
        <div class="alert alert-info small mb-0">
            ℹ️ No formulas found for the selected filter.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm enterprise-table align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width:2.5rem" class="text-center text-muted">#</th>
                        <th>Code</th>
                        <th>Step</th>
                        <th>Channel</th>
                        <th>Position</th>
                        <th>WS Type</th>
                        <th>Expression</th>
                        <th>Active</th>
                        <th class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var f in Model.Formulas)
                {
                    var _stepIdx = AjtIncentive.Web.Pages.Formula.IndexModel.FormulaSteps.ToList().IndexOf(f.FormulaStep);
                    var _stepSeq = _stepIdx >= 0 ? _stepIdx + 1 : 0;
                    <tr>
                        <td class="text-center">
                            <span class="fw-bold text-secondary" style="font-size:0.85rem">@f.SortOrder</span>
                        </td>
                        <td>
                            <div class="fw-semibold small">@f.FormulaCode</div>
                            <div class="small text-muted">@f.FormulaName</div>
                        </td>
                        <td>
                            <span class="badge bg-info text-dark">@f.FormulaStep</span>
                            @if (_stepSeq > 0)
                            {
                                <div class="small text-muted mt-1" style="font-size:0.7rem">Step @_stepSeq of @AjtIncentive.Web.Pages.Formula.IndexModel.FormulaSteps.Count</div>
                            }
                        </td>
                        <td>@(f.ChannelCode ?? "SHARED")</td>
                        <td>@(f.PositionCode ?? "—")</td>
                        <td>@(f.WsType ?? "—")</td>
                        <td>
                            <code class="small text-primary">@f.FormulaExpr</code>
                            @if (!string.IsNullOrWhiteSpace(f.Description))
                            {
                                <div class="small text-muted">@f.Description</div>
                            }
                        </td>
                        <td>
                            @if (f.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm" role="group">
                                <form method="get" class="d-inline">
                                    <input type="hidden" name="FilterChannel" value="@Model.FilterChannel" />
                                    <input type="hidden" name="FilterStep" value="@Model.FilterStep" />
                                    <input type="hidden" name="EditId" value="@f.FormulaId" />
                                    <button type="submit" class="btn btn-outline-primary" title="Edit">✎</button>
                                </form>
                                <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('Delete @f.FormulaCode?');">
                                    <input type="hidden" name="formulaId" value="@f.FormulaId" />
                                    <button type="submit" class="btn btn-outline-danger" title="Delete">✕</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="content-panel mb-4 mt-modern-card mt-fade-in mt-fade-in-delay-2">
    <div class="eyebrow mb-2">Editor</div>
    <h5 class="h6 fw-semibold mb-3">@(Model.IsEditMode ? "Edit Formula" : "Add New Formula")</h5>
    <form method="post" asp-page-handler="Save" class="row g-3">
        <input type="hidden" name="formulaId" value="@Model.EditForm.FormulaId" />

        <div class="col-md-3">
            <label class="form-label small fw-semibold">Formula Code <span class="text-danger">*</span></label>
            <input type="text" name="formulaCode" class="form-control form-control-sm text-uppercase"
                   value="@Model.EditForm.FormulaCode" required placeholder="MT_STAFF_INCENTIVE_PER_PRODUCT" />
        </div>
        <div class="col-md-5">
            <label class="form-label small fw-semibold">Formula Name <span class="text-danger">*</span></label>
            <input type="text" name="formulaName" class="form-control form-control-sm"
                   value="@Model.EditForm.FormulaName" required />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Step <span class="text-danger">*</span></label>
            <select name="formulaStep" class="form-select form-select-sm" required>
                @foreach (var s in AjtIncentive.Web.Pages.Formula.IndexModel.FormulaSteps)
                {
                    <option value="@s" selected="@(s == Model.EditForm.FormulaStep)">@s</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Sort Order</label>
            <input type="number" name="sortOrder" class="form-control form-control-sm"
                   value="@Model.EditForm.SortOrder" min="0" />
        </div>

        <div class="col-md-3">
            <label class="form-label small fw-semibold">Channel</label>
            <select name="channelId" class="form-select form-select-sm">
                <option value="">— SHARED (all channels) —</option>
                @foreach (var c in Model.Channels)
                {
                    <option value="@c.ChannelId" selected="@(c.ChannelId == Model.EditForm.ChannelId)">@c.ChannelCode</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Position Level</label>
            <select name="positionLevelId" class="form-select form-select-sm">
                <option value="">— All Positions —</option>
                @foreach (var p in Model.Positions)
                {
                    <option value="@p.PositionLevelId" selected="@(p.PositionLevelId == Model.EditForm.PositionLevelId)">
                        @p.PositionCode — @p.PositionNameTh
                    </option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">WS Type</label>
            <input type="text" name="wsType" class="form-control form-control-sm"
                   value="@Model.EditForm.WsType" placeholder="TOP_WS, WS_SF …" />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Effective From</label>
            <input type="date" name="effectiveFrom" class="form-control form-control-sm"
                   value="@Model.EditForm.EffectiveFrom.ToString("yyyy-MM-dd")" required />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Effective To</label>
            <input type="date" name="effectiveTo" class="form-control form-control-sm"
                   value="@(Model.EditForm.EffectiveTo.HasValue ? Model.EditForm.EffectiveTo.Value.ToString("yyyy-MM-dd") : string.Empty)" />
        </div>

        <div class="col-12">
            <label class="form-label small fw-semibold">Formula Expression <span class="text-danger">*</span></label>
            <input type="text" name="formulaExpr" class="form-control form-control-sm font-monospace"
                   value="@Model.EditForm.FormulaExpr" required
                   placeholder="ROUND([base_rate] * [weight_pct] * [goal_mult], 0)" />
            <div class="form-text">Use variables in the format <code>[variable_name]</code> — supports +, -, *, /, ROUND(), IIF(), ABS()</div>
        </div>

        <div class="col-12">
            <label class="form-label small fw-semibold">Variables JSON</label>
            <textarea name="variablesJson" class="form-control form-control-sm font-monospace" rows="2"
                      placeholder='{"base_rate":"mst_incentive_rate.rate_effective","weight_pct":"mst_product_weight.weight_percent","goal_mult":"mst_goal_threshold.multiplier"}'>@Model.EditForm.VariablesJson</textarea>
            <div class="form-text">Describe the source table/column mapping for each variable (JSON).</div>
        </div>

        <div class="col-md-8">
            <label class="form-label small fw-semibold">Description</label>
            <input type="text" name="description" class="form-control form-control-sm"
                   value="@Model.EditForm.Description" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <div class="form-check mb-1">
                <input type="checkbox" name="isActive" class="form-check-input" value="true" id="chkActive"
                       checked="@Model.EditForm.IsActive" />
                <label class="form-check-label small fw-semibold" for="chkActive">Active</label>
            </div>
        </div>

        <div class="col-md-2 d-flex align-items-end gap-2">
            <button type="submit" class="btn target-filter-btn target-filter-btn--primary btn-sm">
                @(Model.IsEditMode ? "Save" : "Add Formula")
            </button>
            @if (Model.IsEditMode)
            {
                <a class="btn target-filter-btn target-filter-btn--secondary btn-sm"
                   asp-page="./Index"
                   asp-route-FilterChannel="@Model.FilterChannel"
                   asp-route-FilterStep="@Model.FilterStep">Cancel</a>
            }
        </div>
    </form>
</div>

<div class="content-panel mt-modern-card mt-fade-in mt-fade-in-delay-2">
    <div class="eyebrow mb-2">Validation</div>
    <h5 class="h6 fw-semibold mb-3">Test Formula Expression</h5>

    <ul class="nav nav-tabs mb-3" id="testTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link @(Model.ActiveTestTab == "quick" ? "active" : "")"
                    id="tab-quick" data-bs-toggle="tab" data-bs-target="#panel-quick"
                    type="button" role="tab">
                ⚡ Quick Test <small class="text-muted">(NCalc)</small>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(Model.ActiveTestTab == "sp" ? "active" : "")"
                    id="tab-sp" data-bs-toggle="tab" data-bs-target="#panel-sp"
                    type="button" role="tab">
                🗄️ Preview via SP <small class="text-muted">(same path as real calculation)</small>
            </button>
        </li>
    </ul>

    <div class="tab-content">

        <div class="tab-pane fade @(Model.ActiveTestTab == "quick" ? "show active" : "")"
             id="panel-quick" role="tabpanel">
            <form method="post" asp-page-handler="Test" class="row g-3">
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Formula Expression</label>
                    <input type="text" name="formulaExpr" class="form-control form-control-sm font-monospace"
                           value="@(Model.TestResult?.FormulaExpr ?? "ROUND([base_rate] * [weight_pct] * [goal_mult], 0)")"
                           placeholder="ROUND([base_rate] * [weight_pct] * [goal_mult], 0)" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Variables (JSON)</label>
                    <input type="text" name="testVarsJson" class="form-control form-control-sm font-monospace"
                           value='{"base_rate":4000,"weight_pct":0.25,"goal_mult":1.1}'
                           placeholder='{"base_rate":4000,"weight_pct":0.25,"goal_mult":1.1}' />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn target-filter-btn target-filter-btn--primary btn-sm w-100">Run Test</button>
                </div>
            </form>

            @if (Model.TestResult is not null)
            {
                <div class="mt-3 p-3 rounded @(Model.TestResult.Success ? "bg-success-subtle border border-success" : "bg-danger-subtle border border-danger")">
                    @if (Model.TestResult.Success)
                    {
                        <div class="fw-bold text-success fs-5">Result: @Model.TestResult.Value.ToString("N4")</div>
                        <div class="small text-muted mt-1">
                            <code>@Model.TestResult.FormulaExpr</code>
                        </div>
                        <div class="small text-muted">
                            Variables: @string.Join(", ", Model.TestResult.Variables.Select(kv => $"{kv.Key} = {kv.Value}"))
                        </div>
                    }
                    else
                    {
                        <div class="fw-bold text-danger">Error: @Model.TestResult.ErrorMessage</div>
                    }
                </div>
            }

            <div class="mt-callout mt-3">
                <strong>Supported variables:</strong>
                <code>[actual_amount]</code>, <code>[target_amount]</code>, <code>[base_rate]</code>,
                <code>[weight_pct]</code>, <code>[goal_mult]</code>, <code>[pct_achievement]</code>,
                <code>[special_kpi]</code>, <code>[kpi_threshold]</code>, <code>[bonus_amount]</code>,
                <code>[sum_incentive_per_product]</code><br/>
                <strong>Functions:</strong> <code>ROUND(x, dp)</code>, <code>IIF(cond, a, b)</code>,
                <code>ABS(x)</code>, <code>MAX(a, b)</code>, <code>MIN(a, b)</code>
            </div>
        </div>

        <div class="tab-pane fade @(Model.ActiveTestTab == "sp" ? "show active" : "")"
             id="panel-sp" role="tabpanel">
            <div class="mt-callout mb-3">
                Calls <code>usp_formula_expression_preview</code> — the same execution path as the real incentive calculation.
                Use this to verify that saved formulas produce correct results against live system data.
            </div>
            <form method="post" asp-page-handler="Preview" class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Period <span class="text-danger">*</span></label>
                    <select name="previewPeriodId" class="form-select form-select-sm" required>
                        <option value="">— Select Period —</option>
                        @foreach (var p in Model.Periods)
                        {
                            <option value="@p.PeriodId" selected="@(p.PeriodId == Model.PreviewPeriodId)">
                                @p.PeriodCode
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Channel <span class="text-danger">*</span></label>
                    <select name="previewChannel" class="form-select form-select-sm" required>
                        <option value="">— Select Channel —</option>
                        @foreach (var c in Model.Channels)
                        {
                            <option value="@c.ChannelCode" selected="@(c.ChannelCode == Model.PreviewChannel)">
                                @c.ChannelCode
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn target-filter-btn target-filter-btn--primary btn-sm">
                        Run SP Preview
                    </button>
                </div>
            </form>

            @if (!string.IsNullOrEmpty(Model.PreviewError))
            {
                <div class="alert alert-danger small">⚠️ SP Error: @Model.PreviewError</div>
            }
            else if (Model.PreviewRows.Count > 0)
            {
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="small fw-semibold">
                        Period: <strong>@Model.PreviewPeriodId</strong> / Channel: <strong>@Model.PreviewChannel</strong>
                    </span>
                    <span class="mt-kpi-chip">
                        <span class="mt-kpi-label">Rows</span>
                        <span class="mt-kpi-value">@Model.PreviewRows.Count</span>
                    </span>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm enterprise-table align-middle mb-0" style="font-size:0.78rem;">
                        <thead>
                            <tr>
                                <th>Salesman</th>
                                <th>Position</th>
                                <th>Product</th>
                                <th class="text-end">% Achv</th>
                                <th class="text-end">GoalMult</th>
                                <th class="text-end">BaseRate</th>
                                <th class="text-end">WeightPct</th>
                                <th>Formula (Incent)</th>
                                <th class="text-end fw-bold">Incentive</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var r in Model.PreviewRows.Take(50))
                        {
                            <tr>
                                <td>@r.SalesmanCode</td>
                                <td>@r.PositionCode</td>
                                <td>@r.ProductCode</td>
                                <td class="text-end">@r.PctAchievement.ToString("F1")%</td>
                                <td class="text-end">@r.GoalMult.ToString("F3")</td>
                                <td class="text-end">@r.BaseRate.ToString("N0")</td>
                                <td class="text-end">@r.WeightPct.ToString("F3")</td>
                                <td><code class="small text-primary">@r.FormulaCodeIncent</code></td>
                                <td class="text-end fw-bold">@r.IncentiveAmount.ToString("N0")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
                @if (Model.PreviewRows.Count > 50)
                {
                    <div class="small text-muted mt-1">Showing first 50 of @Model.PreviewRows.Count rows</div>
                }
            }
            else if (Model.ActiveTestTab == "sp" && Model.PreviewRows.Count == 0 && string.IsNullOrEmpty(Model.PreviewError))
            {
                <div class="alert alert-info small mb-0">Select a Period and Channel, then click <strong>Run SP Preview</strong>.</div>
            }
        </div>

    </div>
</div>

@section Scripts {
<script>
(function () {
    var sel = document.getElementById('filterChannelSelect');
    var wrap = document.getElementById('includeSharedWrap');
    if (!sel || !wrap) return;
    function toggleWrap() {
        var v = sel.value;
        wrap.style.display = (v && v !== 'SHARED') ? 'block' : 'none';
        if (!wrap.style.display || wrap.style.display === 'none') {
            var chk = document.getElementById('chkIncludeShared');
            if (chk) chk.checked = false;
        }
    }
    sel.addEventListener('change', toggleWrap);
}());
</script>
}
