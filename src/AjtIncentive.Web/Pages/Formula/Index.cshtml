@page
@model AjtIncentive.Web.Pages.Formula.IndexModel
@{
    ViewData["Title"] = "Formula Expression";
}

<section class="adj-header-panel mb-4">
    <p class="adj-eyebrow">Config</p>
    <h1 class="adj-title">Formula Expression</h1>
    <p class="adj-desc">Define incentive formula expressions evaluated by the NCalc engine.</p>
</section>

@if (TempData["Message"] is string msg)
{
    var cls = msg.StartsWith("Error") ? "alert-danger" : "alert-success";
    <div class="alert @cls alert-dismissible fade show mb-3" role="alert">
        @msg <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="content-panel mb-4">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Channel</label>
            <select name="FilterChannel" class="form-select form-select-sm">
                <option value="">— All —</option>
                <option value="SHARED" selected="@("SHARED" == Model.FilterChannel)">SHARED (no channel)</option>
                @foreach (var c in Model.Channels)
                {
                    <option value="@c.ChannelCode" selected="@(c.ChannelCode == Model.FilterChannel)">@c.ChannelCode</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Formula Step</label>
            <select name="FilterStep" class="form-select form-select-sm">
                <option value="">— All —</option>
                @foreach (var s in AjtIncentive.Web.Pages.Formula.IndexModel.FormulaSteps)
                {
                    <option value="@s" selected="@(s == Model.FilterStep)">@s</option>
                }
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm">Filter</button>
            <a class="btn btn-outline-secondary btn-sm" asp-page="./Index">Clear</a>
        </div>
    </form>
</div>

{{!-- ── Formula Table ──}}
<div class="content-panel mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-semibold mb-0">Formula Expressions</h6>
        <span class="badge bg-secondary">@Model.Formulas.Count rows</span>
    </div>

    @if (Model.Formulas.Count == 0)
    {
        <div class="adj-empty-state"><span class="text-muted small">No formulas found for the selected filter.</span></div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Code</th>
                        <th>Step</th>
                        <th>Channel</th>
                        <th>Position</th>
                        <th>WS Type</th>
                        <th>Expression</th>
                        <th>Active</th>
                        <th class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var f in Model.Formulas)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold small">@f.FormulaCode</div>
                            <div class="small text-muted">@f.FormulaName</div>
                        </td>
                        <td><span class="badge bg-info text-dark">@f.FormulaStep</span></td>
                        <td>@(f.ChannelCode ?? "SHARED")</td>
                        <td>@(f.PositionCode ?? "—")</td>
                        <td>@(f.WsType ?? "—")</td>
                        <td>
                            <code class="small text-primary">@f.FormulaExpr</code>
                            @if (!string.IsNullOrWhiteSpace(f.Description))
                            {
                                <div class="small text-muted">@f.Description</div>
                            }
                        </td>
                        <td>
                            @if (f.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a class="btn btn-outline-primary"
                                   asp-page="./Index"
                                   asp-route-FilterChannel="@Model.FilterChannel"
                                   asp-route-FilterStep="@Model.FilterStep"
                                   asp-route-EditId="@f.FormulaId">Edit</a>
                                <form method="post" asp-page-handler="Delete" class="d-inline">
                                    <input type="hidden" name="formulaId" value="@f.FormulaId" />
                                    <button type="submit" class="btn btn-outline-danger"
                                            onclick="return confirm('Delete @f.FormulaCode?')">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

{{!-- ── Edit / Add Form ──}}
<div class="content-panel mb-4">
    <h6 class="fw-semibold mb-3">@(Model.IsEditMode ? "Edit Formula" : "Add New Formula")</h6>
    <form method="post" asp-page-handler="Save" class="row g-3">
        <input type="hidden" name="formulaId" value="@Model.EditForm.FormulaId" />

        <div class="col-md-3">
            <label class="form-label small fw-semibold">Formula Code <span class="text-danger">*</span></label>
            <input type="text" name="formulaCode" class="form-control form-control-sm text-uppercase"
                   value="@Model.EditForm.FormulaCode" required placeholder="MT_STAFF_INCENTIVE_PER_PRODUCT" />
        </div>
        <div class="col-md-5">
            <label class="form-label small fw-semibold">Formula Name <span class="text-danger">*</span></label>
            <input type="text" name="formulaName" class="form-control form-control-sm"
                   value="@Model.EditForm.FormulaName" required />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Step <span class="text-danger">*</span></label>
            <select name="formulaStep" class="form-select form-select-sm" required>
                @foreach (var s in AjtIncentive.Web.Pages.Formula.IndexModel.FormulaSteps)
                {
                    <option value="@s" selected="@(s == Model.EditForm.FormulaStep)">@s</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Sort Order</label>
            <input type="number" name="sortOrder" class="form-control form-control-sm"
                   value="@Model.EditForm.SortOrder" min="0" />
        </div>

        <div class="col-md-3">
            <label class="form-label small fw-semibold">Channel</label>
            <select name="channelId" class="form-select form-select-sm">
                <option value="">— SHARED (all channels) —</option>
                @foreach (var c in Model.Channels)
                {
                    <option value="@c.ChannelId" selected="@(c.ChannelId == Model.EditForm.ChannelId)">@c.ChannelCode</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Position Level</label>
            <select name="positionLevelId" class="form-select form-select-sm">
                <option value="">— All Positions —</option>
                @foreach (var p in Model.Positions)
                {
                    <option value="@p.PositionLevelId" selected="@(p.PositionLevelId == Model.EditForm.PositionLevelId)">
                        @p.PositionCode — @p.PositionNameTh
                    </option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">WS Type</label>
            <input type="text" name="wsType" class="form-control form-control-sm"
                   value="@Model.EditForm.WsType" placeholder="TOP_WS, WS_SF …" />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Effective From</label>
            <input type="date" name="effectiveFrom" class="form-control form-control-sm"
                   value="@Model.EditForm.EffectiveFrom.ToString("yyyy-MM-dd")" required />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Effective To</label>
            <input type="date" name="effectiveTo" class="form-control form-control-sm"
                   value="@(Model.EditForm.EffectiveTo.HasValue ? Model.EditForm.EffectiveTo.Value.ToString("yyyy-MM-dd") : string.Empty)" />
        </div>

        <div class="col-12">
            <label class="form-label small fw-semibold">Formula Expression <span class="text-danger">*</span></label>
            <input type="text" name="formulaExpr" class="form-control form-control-sm font-monospace"
                   value="@Model.EditForm.FormulaExpr" required
                   placeholder="ROUND([base_rate] * [weight_pct] * [goal_mult], 0)" />
            <div class="form-text">Use variables in the format <code>[variable_name]</code> — supports +, -, *, /, ROUND(), IIF(), ABS()</div>
        </div>

        <div class="col-12">
            <label class="form-label small fw-semibold">Variables JSON</label>
            <textarea name="variablesJson" class="form-control form-control-sm font-monospace" rows="2"
                      placeholder='{"base_rate":"mst_incentive_rate.rate_effective","weight_pct":"mst_product_weight.weight_percent","goal_mult":"mst_goal_threshold.multiplier"}'>@Model.EditForm.VariablesJson</textarea>
            <div class="form-text">Describe the source table/column mapping for each variable (JSON).</div>
        </div>

        <div class="col-md-8">
            <label class="form-label small fw-semibold">Description</label>
            <input type="text" name="description" class="form-control form-control-sm"
                   value="@Model.EditForm.Description" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <div class="form-check mb-1">
                <input type="checkbox" name="isActive" class="form-check-input" value="true" id="chkActive"
                       checked="@Model.EditForm.IsActive" />
                <label class="form-check-label small fw-semibold" for="chkActive">Active</label>
            </div>
        </div>

        <div class="col-md-2 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-primary btn-sm">
                @(Model.IsEditMode ? "Save" : "Add Formula")
            </button>
            @if (Model.IsEditMode)
            {
                <a class="btn btn-outline-secondary btn-sm"
                   asp-page="./Index"
                   asp-route-FilterChannel="@Model.FilterChannel"
                   asp-route-FilterStep="@Model.FilterStep">Cancel</a>
            }
        </div>
    </form>
</div>

{{!-- ── Test Panel ──}}
<div class="content-panel">
    <h6 class="fw-semibold mb-3">Test Formula Expression</h6>
    <form method="post" asp-page-handler="Test" class="row g-3">
        <div class="col-md-6">
            <label class="form-label small fw-semibold">Formula Expression</label>
            <input type="text" name="formulaExpr" class="form-control form-control-sm font-monospace"
                   value="@(Model.TestResult?.FormulaExpr ?? "ROUND([base_rate] * [weight_pct] * [goal_mult], 0)")"
                   placeholder="ROUND([base_rate] * [weight_pct] * [goal_mult], 0)" required />
        </div>
        <div class="col-md-4">
            <label class="form-label small fw-semibold">Variables (JSON)</label>
            <input type="text" name="testVarsJson" class="form-control form-control-sm font-monospace"
                   value='{"base_rate":4000,"weight_pct":0.25,"goal_mult":1.1}'
                   placeholder='{"base_rate":4000,"weight_pct":0.25,"goal_mult":1.1}' />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-warning btn-sm w-100">Run Test</button>
        </div>
    </form>

    @if (Model.TestResult is not null)
    {
        <div class="mt-3 p-3 rounded @(Model.TestResult.Success ? "bg-success-subtle border border-success" : "bg-danger-subtle border border-danger")">
            @if (Model.TestResult.Success)
            {
                <div class="fw-bold text-success fs-5">Result: @Model.TestResult.Value.ToString("N4")</div>
                <div class="small text-muted mt-1">
                    <code>@Model.TestResult.FormulaExpr</code>
                </div>
                <div class="small text-muted">
                    Variables: @string.Join(", ", Model.TestResult.Variables.Select(kv => $"{kv.Key} = {kv.Value}"))
                </div>
            }
            else
            {
                <div class="fw-bold text-danger">Error: @Model.TestResult.ErrorMessage</div>
            }
        </div>
    }

    <div class="adj-note mt-3">
        <strong>Supported variables:</strong>
        <code>[actual_amount]</code>, <code>[target_amount]</code>, <code>[base_rate]</code>,
        <code>[weight_pct]</code>, <code>[goal_mult]</code>, <code>[pct_achievement]</code>,
        <code>[special_kpi]</code>, <code>[kpi_threshold]</code>, <code>[bonus_amount]</code>,
        <code>[sum_incentive_per_product]</code><br/>
        <strong>Functions:</strong> <code>ROUND(x, dp)</code>, <code>IIF(cond, a, b)</code>,
        <code>ABS(x)</code>, <code>MAX(a, b)</code>, <code>MIN(a, b)</code>
    </div>
</div>
