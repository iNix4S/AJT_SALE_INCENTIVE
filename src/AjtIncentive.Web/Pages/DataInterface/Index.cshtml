@page
@model AjtIncentive.Web.Pages.DataInterface.IndexModel
@{
    ViewData["Title"] = "Validation Gate";

    var summary      = Model.Summary;
    var staging      = Model.StagingStatus;
    var checks       = Model.Checks;
    var recentRuns   = Model.RecentRuns;
    var biErrors     = Model.GateResult?.BiErrors     ?? Array.Empty<AjtIncentive.Web.Services.StagingErrorRow>();
    var hrErrors     = Model.GateResult?.HrErrors     ?? Array.Empty<AjtIncentive.Web.Services.StagingErrorRow>();
    var mtGaps       = Model.GateResult?.MtMappingGaps ?? Array.Empty<AjtIncentive.Web.Services.StagingErrorRow>();

    var overallStatus   = summary?.OverallStatus ?? "PENDING";
    var isPassing       = overallStatus == "PASS";
    var isFailing       = overallStatus == "FAIL";
    var biTotal         = staging?.BiTotalCurrent ?? 0;
    var hrTotal         = staging?.HrTotalCurrent ?? 0;
    var lastRunText     = summary?.RunAt?.ToString("dd/MM HH:mm") ?? "-";

    string CheckIcon(string status) => status switch {
        "PASS"    => "✅",
        "FAIL"    => "❌",
        _         => "⏳"
    };
    string CheckCss(string status) => status switch {
        "PASS"    => "vg-check-card--pass",
        "FAIL"    => "vg-check-card--fail",
        _         => "vg-check-card--pending"
    };
    string BadgeCss(string status) => status switch {
        "PASS"    => "vg-status-badge--pass",
        "FAIL"    => "vg-status-badge--fail",
        _         => "vg-status-badge--pending"
    };
    string OverallBgCss() => overallStatus switch {
        "PASS"  => "vg-overall--pass",
        "FAIL"  => "vg-overall--fail",
        _       => "vg-overall--pending"
    };
}
<div class="data-interface-page">
<section class="content-panel enterprise-hero mb-4">
    <div class="row g-4 align-items-center">
        <div class="col-lg-7">
            <div class="eyebrow mb-2">Data Interface</div>
            <h1 class="display-6 fw-semibold mb-3">Validation Gate</h1>
            <p class="lead mb-3">
                Verify imported BI Sales &amp; HR Employee data quality before running calculations.
            </p>
            <div class="d-flex flex-wrap gap-2">
                <span class="dashboard-status-pill dashboard-status-pill--ready">BI Sales @biTotal.ToString("N0") rows</span>
                <span class="dashboard-status-pill dashboard-status-pill--warning">HR Employees @hrTotal.ToString("N0") rows</span>
                <span class="dashboard-status-pill dashboard-status-pill--blocked">Last validation @lastRunText</span>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="row g-3">
                <div class="col-6">
                    <div class="kpi-card h-100">
                        <div class="kpi-label">BI Sales</div>
                        <div class="kpi-value">@biTotal.ToString("N0")</div>
                        <div class="stat-sub small">Rows loaded for the selected period</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="kpi-card h-100">
                        <div class="kpi-label">HR Employees</div>
                        <div class="kpi-value">@hrTotal.ToString("N0")</div>
                        <div class="stat-sub small">Employee rows checked for readiness</div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="kpi-card">
                        <div class="kpi-label">Last Validation</div>
                        <div class="kpi-value">@lastRunText</div>
                        <div class="stat-sub small">Latest completed run for the selected period</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


@if (TempData["Message"] != null)
{
    <div class="alert alert-info mb-4 calc-alert">@TempData["Message"]</div>
}


<section class="row g-4 mb-4">
    <div class="col-12 col-xl-5">
        <article class="dashboard-channel-card dashboard-channel-card--warning h-100">
            <div class="dashboard-channel-card__head">
                <div>
                    <div class="eyebrow mb-1">Validation Gate</div>
                    <h2 class="h5 mb-1">Run Data Validation</h2>
                    <p class="text-muted mb-0">
                        Select a period and run the 4-group validation check before calculating incentives.
                    </p>
                </div>
                <span class="dashboard-status-pill dashboard-status-pill--warning">Input surface</span>
            </div>

            <div class="mt-3">
                <div class="mb-3">
                    <label for="vg-period" class="form-label fw-semibold">Period</label>
                    <select id="vg-period" class="form-select mt-period-select"
                            onchange="location.href='?PeriodId='+this.value+'&ShowDetails=@Model.ShowDetails.ToString().ToLower()'">
                        @foreach (var period in Model.Periods)
                        {
                            if (period.PeriodId == Model.PeriodId)
                            {
                                <option value="@period.PeriodId" selected>@period.PeriodCode</option>
                            }
                            else
                            {
                                <option value="@period.PeriodId">@period.PeriodCode</option>
                            }
                        }
                    </select>
                    <div class="form-text mt-1">
                        Validation checks BI Sales and HR Employee data for the selected period's sales month.
                    </div>
                </div>

                <div class="vg-workflow-callout p-3 mb-3">
                    <div class="text-muted small fw-semibold mb-2">Remark</div>
                    <ol class="mb-0 ps-3 small">
                        <li class="mb-2">
                            <strong>Period Alignment</strong><br />
                            เช็กว่า BI Sales กับ HR Employee มีข้อมูลอยู่ใน period ที่เลือก และตรงกับ <code>sales_month</code> ของ period นั้น
                        </li>
                        <li class="mb-2">
                            <strong>Required Fields Completeness</strong><br />
                            เช็กว่าฟิลด์สำคัญของแต่ละแถวไม่ว่างหรือไม่เป็น error เช่นข้อมูลยอดขาย, employee code, และฟิลด์บังคับอื่น ๆ
                        </li>
                        <li class="mb-2">
                            <strong>Hierarchy Consistency</strong><br />
                            เช็กว่า employee หรือข้อมูลองค์กร resolve ไปหา <code>mst_org_hierarchy</code> ได้ และโครงสร้าง hierarchy ไม่ขาด
                        </li>
                        <li>
                            <strong>Mapping Completeness (MT)</strong><br />
                            เช็กว่าแถวฝั่ง MT map <code>bi_sales_code</code> ไป <code>salesman_code</code> ได้ครบ ไม่มี mapping gap
                        </li>
                    </ol>
                </div>

                @if (summary != null)
                {
                    <div class="@OverallBgCss() vg-overall-status-block mb-3">
                        @if (isPassing)
                        {
                            <span>✅ All checks passed — ready for calculation.</span>
                        }
                        else if (isFailing)
                        {
                            var failCount = checks.Count(c => c.Status == "FAIL");
                            <span>❌ @failCount check@(failCount != 1 ? "s" : "") failed — fix errors before calculating.</span>
                        }
                        else
                        {
                            <span>⏳ Pending</span>
                        }
                    </div>
                }
                else
                {
                    <div class="vg-overall-status-block vg-overall--pending mb-3">
                        <span>⏳ No validation run yet for this period.</span>
                    </div>
                }

                <form method="post" asp-page-handler="RunValidation" class="d-grid gap-2">
                    <input type="hidden" name="PeriodId" value="@Model.PeriodId" />
                    <input type="hidden" name="ShowDetails" value="@Model.ShowDetails" />
                    <button type="submit" class="btn btn-outline-primary">
                        Preview Data
                    </button>
                    <button type="submit" class="btn btn-primary">
                        🔍 Run Validation Gate
                    </button>
                </form>

                @if (isPassing)
                {
                    <form method="post" asp-page-handler="Proceed" class="mt-3">
                        <input type="hidden" name="PeriodId" value="@Model.PeriodId" />
                        <button type="submit" class="btn btn-primary w-100">
                            ▶ Proceed to Calculation
                        </button>
                    </form>
                }
            </div>
        </article>
    </div>

    <div class="col-12 col-xl-7">
        <article class="dashboard-channel-card dashboard-channel-card--ready h-100">
            <div class="dashboard-channel-card__head">
                <div>
                    <div class="eyebrow mb-1">4-Group Check</div>
                    <h2 class="h5 mb-0">Validation Status</h2>
                </div>
                @if (summary != null)
                {
                    <small class="text-muted">
                        Run #@summary.ValidationRunId &mdash; @summary.RunAt?.ToString("dd MMM yyyy HH:mm")
                    </small>
                }
                else
                {
                    <small class="text-muted">Run Validation Gate to see results</small>
                }
            </div>

            <div class="d-flex flex-column gap-3">
                @foreach (var check in checks)
                {
                    <div class="vg-check-card @CheckCss(check.Status)">
                        <div class="vg-check-card__header">
                            <span class="vg-check-number">@check.CheckNo</span>
                            <span class="vg-check-name">@check.CheckName</span>
                            <span class="vg-status-badge @BadgeCss(check.Status)">
                                @CheckIcon(check.Status) @check.Status
                            </span>
                        </div>
                        <div class="vg-check-card__body">
                            @if (!string.IsNullOrWhiteSpace(check.Detail) && check.Detail != "Run Validation Gate to check.")
                            {
                                <small class="@(check.Status == "FAIL" ? "text-danger fw-semibold" : "text-muted")">
                                    @check.Detail
                                </small>
                                @if (check.Status == "FAIL" && Model.ShowDetails)
                                {
                                    <div class="mt-1">
                                        <a href="#detail-section" class="small">View error details ↓</a>
                                    </div>
                                }
                            }
                            else if (check.Status == "PASS")
                            {
                                <small class="text-muted">
                                    @if (check.CheckNo == 1)
                                    {
                                        @($"BI {Model.Summary?.BiTotalRows:N0} rows / HR {Model.Summary?.HrTotalRows:N0} rows — period aligned ✓")
                                    }
                                    else if (check.CheckNo == 2)
                                    {
                                        @($"BI {Model.Summary?.BiValidRows:N0} valid / HR {Model.Summary?.HrValidRows:N0} valid — no field errors ✓")
                                    }
                                    else if (check.CheckNo == 3)
                                    {
                                        @($"{Model.Summary?.HierarchyRowCount:N0} org hierarchy records found ✓")
                                    }
                                    else
                                    {
                                        <span>All MT bi_sales_code resolved to salesman_code ✓</span>
                                    }
                                </small>
                            }
                            else
                            {
                                <small class="text-muted">@check.Detail</small>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="mt-4 p-3 vg-workflow-callout">
                <div class="text-muted small fw-semibold mb-1">Workflow</div>
                <div class="small">
                    Import BI Sales &amp; HR data &rarr;
                    <strong>Run Validation Gate</strong> &rarr;
                    Fix any errors &rarr;
                    Re-run until PASS &rarr;
                    Proceed to Calculation
                </div>
            </div>
        </article>
    </div>
</section>

</div>


@if (Model.ShowDetails && summary != null)
{
    <div id="detail-section">

        
        <section class="content-panel mt-modern-card mt-fade-in mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <div class="eyebrow">Source: BI / DWH</div>
                    <h2 class="h5 mb-0">BI Sales Import Status</h2>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <span class="badge badge-soft-gray">Period: @summary.PeriodCode</span>
                    <span class="badge badge-soft-gray">
                        Sales Month: @summary.SalesMonth.ToString("yyyy-MM")
                    </span>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6 col-md-3">
                    <div class="kpi-card text-center">
                        <div class="kpi-label">Total</div>
                        <div class="kpi-value">@summary.BiTotalRows.ToString("N0")</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="kpi-card text-center">
                        <div class="kpi-label">Valid</div>
                        <div class="kpi-value text-success">@summary.BiValidRows.ToString("N0")</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="kpi-card text-center">
                        <div class="kpi-label">Invalid</div>
                        <div class="kpi-value @(summary.BiInvalidRows > 0 ? "text-danger" : "text-success")">
                            @summary.BiInvalidRows.ToString("N0")
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="kpi-card text-center">
                        <div class="kpi-label">MT Unmapped</div>
                        <div class="kpi-value @(summary.MtUnmappedRowCount > 0 ? "text-danger" : "text-success")">
                            @summary.MtUnmappedRowCount.ToString("N0")
                        </div>
                    </div>
                </div>
            </div>

            @if (biErrors.Any())
            {
                <h3 class="h6 mb-2 text-danger">BI Sales Errors (@biErrors.Count rows)</h3>
                <div class="table-responsive">
                    <table class="table table-sm enterprise-table vg-error-table">
                        <thead>
                            <tr>
                                <th>Row #</th>
                                <th>Channel</th>
                                <th>BI Sales Code</th>
                                <th>Error Code</th>
                                <th>Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in biErrors)
                            {
                                <tr>
                                    <td>@row.RawRowNo</td>
                                    <td><span class="badge badge-soft-gray">@row.ChannelCode</span></td>
                                    <td class="font-monospace small">@row.BusinessKey</td>
                                    <td><span class="badge badge-soft-red">@row.ErrorCode</span></td>
                                    <td class="small">@row.ErrorMessage</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else if (summary.BiInvalidRows == 0)
            {
                <div class="text-success small fw-semibold">✅ All BI Sales rows are valid — no errors found.</div>
            }

            @if (mtGaps.Any())
            {
                <h3 class="h6 mb-2 text-danger mt-4">MT Mapping Gaps (@mtGaps.Count rows)</h3>
                <div class="table-responsive">
                    <table class="table table-sm enterprise-table vg-error-table">
                        <thead>
                            <tr>
                                <th>Row #</th>
                                <th>Channel</th>
                                <th>BI Sales Code</th>
                                <th>Error Code</th>
                                <th>Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in mtGaps)
                            {
                                <tr>
                                    <td>@row.RawRowNo</td>
                                    <td><span class="badge badge-soft-gray">@row.ChannelCode</span></td>
                                    <td class="font-monospace small">@row.BusinessKey</td>
                                    <td><span class="badge badge-soft-red">@row.ErrorCode</span></td>
                                    <td class="small">@row.ErrorMessage</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else if (summary.MtUnmappedRowCount == 0)
            {
                <div class="text-success small fw-semibold mt-2">✅ All MT bi_sales_code values are mapped correctly.</div>
            }
        </section>

        
        <section class="content-panel mt-modern-card mt-fade-in mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <div class="eyebrow">Source: HR / HCM</div>
                    <h2 class="h5 mb-0">HR Employee Import Status</h2>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <span class="badge badge-soft-gray">Period: @summary.PeriodCode</span>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6 col-md-4">
                    <div class="kpi-card text-center">
                        <div class="kpi-label">Total</div>
                        <div class="kpi-value">@summary.HrTotalRows.ToString("N0")</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="kpi-card text-center">
                        <div class="kpi-label">Valid</div>
                        <div class="kpi-value text-success">@summary.HrValidRows.ToString("N0")</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="kpi-card text-center">
                        <div class="kpi-label">Invalid</div>
                        <div class="kpi-value @(summary.HrInvalidRows > 0 ? "text-danger" : "text-success")">
                            @summary.HrInvalidRows.ToString("N0")
                        </div>
                    </div>
                </div>
            </div>

            @if (hrErrors.Any())
            {
                <h3 class="h6 mb-2 text-danger">HR Employee Errors (@hrErrors.Count rows)</h3>
                <div class="table-responsive">
                    <table class="table table-sm enterprise-table vg-error-table">
                        <thead>
                            <tr>
                                <th>Row #</th>
                                <th>Channel</th>
                                <th>Employee Code</th>
                                <th>Error Code</th>
                                <th>Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in hrErrors)
                            {
                                <tr>
                                    <td>@row.RawRowNo</td>
                                    <td><span class="badge badge-soft-gray">@row.ChannelCode</span></td>
                                    <td class="font-monospace small">@row.BusinessKey</td>
                                    <td><span class="badge badge-soft-red">@row.ErrorCode</span></td>
                                    <td class="small">@row.ErrorMessage</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else if (summary.HrInvalidRows == 0 && summary.HrTotalRows > 0)
            {
                <div class="text-success small fw-semibold">✅ All HR Employee rows are valid — no errors found.</div>
            }
            else if (summary.HrTotalRows == 0)
            {
                <div class="text-warning small fw-semibold">⚠️ No HR Employee data found for this period.</div>
            }
        </section>

    </div>
}


@if (recentRuns.Any())
{
    <section class="content-panel mt-modern-card mt-fade-in mt-fade-in-delay-2 mb-4">
        <div class="eyebrow mb-1">History</div>
        <h2 class="h5 mb-3">Recent Validation Runs</h2>
        <div class="table-responsive">
            <table class="table table-sm enterprise-table">
                <thead>
                    <tr>
                        <th>Run #</th>
                        <th>Status</th>
                        <th>Date / Time</th>
                        <th>Run By</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var run in recentRuns)
                    {
                        <tr>
                            <td>#@run.ValidationRunId</td>
                            <td>
                                @if (run.OverallStatus == "PASS")
                                {
                                    <span class="badge badge-soft-green">✅ PASS</span>
                                }
                                else if (run.OverallStatus == "FAIL")
                                {
                                    <span class="badge badge-soft-red">❌ FAIL</span>
                                }
                                else
                                {
                                    <span class="badge badge-soft-gray">@run.OverallStatus</span>
                                }
                            </td>
                            <td class="small">@run.RunAt?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="small">@run.RunBy</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

@section Scripts {
<script>
    // Sync the period dropdown with the current PeriodId from server
    (function () {
        const select = document.getElementById('vg-period');
        if (select) {
            select.value = '@Model.PeriodId';
        }
    })();
</script>
}
