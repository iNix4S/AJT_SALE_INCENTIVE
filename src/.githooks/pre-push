#!/bin/sh
set -eu

zero_sha='0000000000000000000000000000000000000000'
violations_file=$(mktemp)
trap 'rm -f "$violations_file"' EXIT

collect_files_for_range() {
  local_ref="$1"
  local_sha="$2"
  remote_ref="$3"
  remote_sha="$4"

  if [ "$local_sha" = "$zero_sha" ]; then
    return 0
  fi

  if [ "$remote_sha" = "$zero_sha" ]; then
    commits=$(git rev-list "$local_sha" --not --remotes)
  else
    commits=$(git rev-list "$remote_sha..$local_sha")
  fi

  if [ -z "$commits" ]; then
    return 0
  fi

  # shellcheck disable=SC2086
  git diff-tree --no-commit-id --name-only -r $commits | sed '/^$/d'
}

while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "$local_ref" ] && continue

  collect_files_for_range "$local_ref" "$local_sha" "$remote_ref" "$remote_sha" >> "$violations_file.tmp"
done

if [ -f "$violations_file.tmp" ]; then
  sort -u "$violations_file.tmp" > "$violations_file"
  rm -f "$violations_file.tmp"
fi

if [ ! -s "$violations_file" ]; then
  exit 0
fi

outside_src=$(grep -v '^src/' "$violations_file" || true)
if [ -z "$outside_src" ]; then
  exit 0
fi

echo "Push blocked: only files under src/ are allowed in pushed commits." >&2
echo "Files outside src/:" >&2
printf '%s\n' "$outside_src" >&2
exit 1
