# ============================================================
# .gitignore — AJT New Sale Incentive
# ============================================================

# ── Credentials / Secrets ──────────────────────────────────
*.env
*.env.*
!*.env.example
database-dev*.env

# .NET user secrets & dev config (contains real passwords)
appsettings.Development.json
appsettings.*.Local.json
secrets.json

# Files containing API keys / personal credentials
"5.Docs/Cline VS Code (claude).md"
5.Docs/Cline*

# ── OS / System ────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── VS Code ────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace

# ── .NET Build Artifacts ───────────────────────────────────
bin/
obj/
*.user
*.suo
.vs/
_ReSharper*/
*.ncrunch*
publish/
*.pubxml
*.pubxml.user

# ── Node (Chart.js dev) ────────────────────────────────────
node_modules/
npm-debug.log*

# ── Temp / Generated ───────────────────────────────────────
environment/generated/
*.tmp
*.temp
~$*
_backup_ui_*/

# ── Binary Deliverables (ไม่ track ด้วย git — ใช้ SharePoint/Drive แทน) ──
deliver-docs/*.pptx
deliver-docs/*.docx
deliver-docs/*.xlsx
deliver-docs/*.pdf
3.Estimate\ Manday\(s\)/*.pptx
3.Estimate\ Manday\(s\)/*.docx

# ── SQL Server Backups ─────────────────────────────────────
*.bak
*.mdf
*.ldf

# ── Logs ───────────────────────────────────────────────────
logs/
*.log
