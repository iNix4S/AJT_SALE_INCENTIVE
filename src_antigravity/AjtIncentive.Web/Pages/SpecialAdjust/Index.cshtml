@page
@model AjtIncentive.Web.Pages.SpecialAdjust.IndexModel
@{
    ViewData["Title"] = "Special Adjustment";
}

<section class="content-panel mb-4 calc-header-panel adj-modern-header">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <div class="eyebrow">Adjustments</div>
            <h1 class="h3 mb-1">Special Adjustment</h1>
            <p class="text-muted mb-0">จัดการการปรับ Incentive สำหรับกรณีพิเศษ เช่น Shortage และ Special Situation / Manage incentive adjustments for special cases such as Shortage and Special Situation.</p>
        </div>
        <div class="calc-master-pill">@Model.SelectedChannelCode / @Model.SelectedPeriodCode</div>
    </div>
</section>

<section class="row g-3 mb-4">
    <div class="col-12 col-md-4">
        <article class="content-panel h-100 adj-stat-card">
            <div class="eyebrow">Shortage</div>
            <h2 class="h6 mb-1">Active Records</h2>
            <div class="display-6 fw-semibold">@Model.ShortageRecords.Count</div>
            <p class="text-muted mb-0 small">เคสที่ปรับตาม config ของระบบ / Config-driven override cases</p>
        </article>
    </div>
    <div class="col-12 col-md-4">
        <article class="content-panel h-100 adj-stat-card">
            <div class="eyebrow">Special</div>
            <h2 class="h6 mb-1">Situation Records</h2>
            <div class="display-6 fw-semibold">@Model.SpecialRecords.Count</div>
            <p class="text-muted mb-0 small">เคสที่ต้องอนุมัติและมีน้ำหนัก / Approval-driven weighted cases</p>
        </article>
    </div>
    <div class="col-12 col-md-4">
        <article class="content-panel h-100 adj-stat-card">
            <div class="eyebrow">Master Data</div>
            <h2 class="h6 mb-1">Reference Products</h2>
            <div class="display-6 fw-semibold">@Model.Products.Count</div>
            <p class="text-muted mb-0 small">ขอบเขตสินค้าอ้างอิงที่ใช้งานได้ / Available product reference scope</p>
        </article>
    </div>
</section>

@if (TempData["Message"] is string msg)
{
    var cls = msg.StartsWith("Error") ? "alert-danger" : "alert-success";
    <div class="alert @cls alert-dismissible fade show mb-3" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Filter -->
<div class="content-panel mb-4 adj-shell">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label small fw-semibold">Channel</label>
            <select name="ChannelId" class="form-select form-select-sm" style="min-width:130px;">
                @foreach (var c in Model.Channels)
                {
                    <option value="@c.ChannelId" selected="@(c.ChannelId == Model.ChannelId)">@c.ChannelCode – @c.ChannelNameEn</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label small fw-semibold">Period</label>
            <select name="PeriodId" class="form-select form-select-sm" style="min-width:130px;">
                @foreach (var p in Model.Periods)
                {
                    <option value="@p.PeriodId" selected="@(p.PeriodId == Model.PeriodId)">@p.PeriodCode</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary btn-sm">Load</button>
        </div>
    </form>
    <p class="text-muted small mb-0 mt-2">เลือก Channel และ Period เพื่อดูรายการปรับในรอบนั้น / Select channel and period to view adjustment records in that cycle.</p>
</div>

<!-- Rule Reference -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="content-panel">
            <h6 class="fw-semibold mb-3">Special Adjustment Types (Function 4)</h6>
            <p class="text-muted small mb-3">คำอธิบายชนิดการปรับเพื่อสื่อสารให้ตรงกันระหว่าง HR, Finance และทีมระบบ / Adjustment type definitions for aligned communication among HR, Finance, and system team.</p>
            <div class="table-responsive">
                <table class="table table-sm enterprise-table mb-0 small">
                    <thead>
                        <tr><th>Type</th><th>Description</th><th>Logic</th></tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="badge bg-danger">SHORTAGE</span></td>
                            <td>ยอดขายต่ำกว่าเป้าเพราะสินค้าขาด ไม่ใช่เพราะผลงานต่ำ / Sales below target due to stock shortage, not poor performance</td>
                            <td>ปรับ achievement เป็นมาตรฐาน 100% ตามแบรนด์ / Override actual achievement to standard 100% by brand</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-warning text-dark">SPECIAL_SITUATION</span></td>
                            <td>พนักงานรับงานเพิ่มชั่วคราวหรือได้รับผลกระทบจากปัจจัยภายนอก / Employee temporarily covers additional outlets/products or is affected by external events</td>
                            <td>ปรับเป้ายอดขายและ/หรือน้ำหนักสัดส่วน / Adjust sales target and/or allocation weight percent</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs mb-0" id="adjTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="shortage-tab" data-bs-toggle="tab"
                data-bs-target="#shortage-pane" type="button" role="tab">
            <span class="badge bg-danger me-1">SHORTAGE</span> Shortage (@Model.ShortageRecords.Count)
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="special-tab" data-bs-toggle="tab"
                data-bs-target="#special-pane" type="button" role="tab">
            <span class="badge bg-warning text-dark me-1">SPECIAL</span> Special Situation (@Model.SpecialRecords.Count)
        </button>
    </li>
</ul>

<div class="tab-content content-panel rounded-top-0 border-top-0 adj-shell">

    <!-- ═══════════════════════════════════════════ SHORTAGE TAB -->
    <div class="tab-pane fade show active" id="shortage-pane" role="tabpanel">
        <h6 class="fw-semibold mb-3 mt-1">Shortage Adjustments — @Model.SelectedChannelCode / @Model.SelectedPeriodCode</h6>
        <p class="text-muted small mb-3">รายการปรับกรณีสินค้าขาดที่ถูกบันทึกสำหรับงวดนี้ / Logged shortage adjustment records for this period.</p>

        @if (Model.ShortageRecords.Count == 0)
        {
            <div class="adj-empty-state mb-3">
                <span class="text-muted small">No shortage adjustments for this channel/period.</span>
            </div>
        }
        else
        {
            <div class="table-responsive mb-4">
                <table class="table table-sm table-hover enterprise-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Product Code</th>
                            <th class="text-center">Override Achievement</th>
                            <th>Reason</th>
                            <th>Approved By</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.ShortageRecords)
                        {
                            <tr>
                                <td>@(string.IsNullOrEmpty(r.EmployeeCode) ? "<all>" : r.EmployeeCode)</td>
                                <td class="fw-semibold">@r.ProductCode</td>
                                <td class="text-center">
                                    <span class="badge bg-success">@(r.OverrideAchievement?.ToString("P0") ?? "1.0000")</span>
                                </td>
                                <td class="text-muted small">@r.Reason</td>
                                <td class="text-muted small">@r.ApprovedBy</td>
                                <td>
                                    <form method="post" asp-page-handler="Delete" class="d-inline">
                                        <input type="hidden" name="AdjustmentId" value="@r.AdjustmentId" />
                                        <input type="hidden" name="ChannelId" value="@Model.ChannelId" />
                                        <input type="hidden" name="PeriodId" value="@Model.PeriodId" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-1"
                                                onclick="return confirm('Delete this shortage record?')">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- Add Shortage -->
        <div class="adj-add-panel">
            <h6 class="small fw-semibold mb-2">Add Shortage Adjustment</h6>
            <p class="text-muted small mb-2">ระบุเหตุผลและผู้อนุมัติเพื่อเก็บ audit trail ที่ครบถ้วน / Provide reason and approver to keep complete audit trail.</p>
            <form method="post" asp-page-handler="SaveShortage" class="row g-2 align-items-end">
                <input type="hidden" name="ChannelId" value="@Model.ChannelId" />
                <input type="hidden" name="PeriodId" value="@Model.PeriodId" />
                <div class="col-md-2">
                    <label class="form-label small">Employee (blank = all)</label>
                    <select name="EmployeeCode" class="form-select form-select-sm">
                        <option value="">-- All Employees --</option>
                        @foreach (var e in Model.Employees)
                        {
                            <option value="@e.EmployeeCode">@e.EmployeeCode</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Product Code</label>
                    <select name="ProductCode" class="form-select form-select-sm" required>
                        <option value="">-- Select Product --</option>
                        @foreach (var p in Model.Products)
                        {
                            <option value="@p.ProductCode">@p.ProductCode</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Override Achievement (1.0 = 100%)</label>
                    <input type="number" name="OverrideAchievement" class="form-control form-control-sm"
                           step="0.0001" min="0" max="2" value="1.0000" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Reason</label>
                    <input type="text" name="Reason" class="form-control form-control-sm"
                           placeholder="e.g. Stock shortage Apr-2026" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Approved By</label>
                    <input type="text" name="ApprovedBy" class="form-control form-control-sm"
                           placeholder="Approver name" />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-danger btn-sm w-100">Save</button>
                </div>
            </form>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════ SPECIAL SITUATION TAB -->
    <div class="tab-pane fade" id="special-pane" role="tabpanel">
        <h6 class="fw-semibold mb-3 mt-1">Special Situation Adjustments — @Model.SelectedChannelCode / @Model.SelectedPeriodCode</h6>
        <p class="text-muted small mb-3">รายการปรับเงื่อนไขพิเศษ เช่น เป้าหมายหรือ weight ของ incentive / Special condition adjustments such as target or incentive weight.</p>

        @if (Model.SpecialRecords.Count == 0)
        {
            <div class="adj-empty-state mb-3">
                <span class="text-muted small">No special situation adjustments for this channel/period.</span>
            </div>
        }
        else
        {
            <div class="table-responsive mb-4">
                <table class="table table-sm table-hover enterprise-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Product Code</th>
                            <th class="text-end">Adjusted Target</th>
                            <th class="text-end">Adjusted Weight%</th>
                            <th>Reason</th>
                            <th>Approved By</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.SpecialRecords)
                        {
                            <tr>
                                <td>@(string.IsNullOrEmpty(r.EmployeeCode) ? "<all>" : r.EmployeeCode)</td>
                                <td class="fw-semibold">@r.ProductCode</td>
                                <td class="text-end">@(r.AdjustedTargetAmount.HasValue ? r.AdjustedTargetAmount.Value.ToString("N0") : "—")</td>
                                <td class="text-end">@(r.AdjustedWeightPercent.HasValue ? r.AdjustedWeightPercent.Value.ToString("P2") : "—")</td>
                                <td class="text-muted small">@r.Reason</td>
                                <td class="text-muted small">@r.ApprovedBy</td>
                                <td>
                                    <form method="post" asp-page-handler="Delete" class="d-inline">
                                        <input type="hidden" name="AdjustmentId" value="@r.AdjustmentId" />
                                        <input type="hidden" name="ChannelId" value="@Model.ChannelId" />
                                        <input type="hidden" name="PeriodId" value="@Model.PeriodId" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-1"
                                                onclick="return confirm('Delete this special record?')">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- Add Special Situation -->
        <div class="adj-add-panel">
            <h6 class="small fw-semibold mb-2">Add Special Situation Adjustment</h6>
            <p class="text-muted small mb-2">กรอกค่าที่จำเป็นเฉพาะกรณี และยืนยันเหตุผลทุกครั้ง / Fill only required fields per case and always provide reason.</p>
            <form method="post" asp-page-handler="SaveSpecial" class="row g-2 align-items-end">
                <input type="hidden" name="ChannelId" value="@Model.ChannelId" />
                <input type="hidden" name="PeriodId" value="@Model.PeriodId" />
                <div class="col-md-2">
                    <label class="form-label small">Employee (blank = all)</label>
                    <select name="EmployeeCode" class="form-select form-select-sm">
                        <option value="">-- All Employees --</option>
                        @foreach (var e in Model.Employees)
                        {
                            <option value="@e.EmployeeCode">@e.EmployeeCode</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Product Code</label>
                    <select name="ProductCode" class="form-select form-select-sm">
                        <option value="">-- Select Product --</option>
                        @foreach (var p in Model.Products)
                        {
                            <option value="@p.ProductCode">@p.ProductCode</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Adjusted Target Amount</label>
                    <input type="number" name="AdjustedTargetAmount" class="form-control form-control-sm"
                           step="1000" min="0" placeholder="e.g. 1500000" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Adjusted Weight% (e.g. 0.35)</label>
                    <input type="number" name="AdjustedWeightPercent" class="form-control form-control-sm"
                           step="0.0001" min="0" max="1" placeholder="e.g. 0.3500" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Reason <span class="text-danger">*</span></label>
                    <input type="text" name="Reason" class="form-control form-control-sm"
                           placeholder="e.g. Temporary product addition" required />
                </div>
                <div class="col-md-1">
                    <label class="form-label small">Approved By</label>
                    <input type="text" name="ApprovedBy" class="form-control form-control-sm"
                           placeholder="Approver" />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-warning btn-sm w-100">Save</button>
                </div>
            </form>
        </div>
    </div>

</div>
