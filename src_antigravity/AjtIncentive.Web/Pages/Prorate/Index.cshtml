@page
@model AjtIncentive.Web.Pages.Prorate.IndexModel
@{
    ViewData["Title"] = "Prorate";
}

<section class="content-panel mb-4 calc-header-panel adj-modern-header">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <div class="eyebrow">Adjustments</div>
            <h1 class="h3 mb-1">Prorate Logic</h1>
            <p class="text-muted mb-0">บันทึกและจำลองปัจจัย Prorate สำหรับพนักงานที่เริ่มงาน ลาออก หรือย้ายงานกลางงวด / Record and simulate prorate factors for employees joining, resigning, or transferring mid-period.</p>
        </div>
        <div class="calc-master-pill">@Model.SelectedChannelCode / @Model.SelectedPeriodCode</div>
    </div>
</section>

<section class="row g-3 mb-4">
    <div class="col-12 col-md-4">
        <article class="content-panel h-100 adj-stat-card">
            <div class="eyebrow">Reference</div>
            <h2 class="h6 mb-1">Active Formulas</h2>
            <div class="display-6 fw-semibold">@Model.ActiveFormulas.Count</div>
            <p class="text-muted mb-0 small">สูตรที่เปิดใช้งานจากมุมมองระบบ / Active formulas from system view</p>
        </article>
    </div>
    <div class="col-12 col-md-4">
        <article class="content-panel h-100 adj-stat-card">
            <div class="eyebrow">Execution</div>
            <h2 class="h6 mb-1">Test Cases</h2>
            <div class="display-6 fw-semibold">@Model.TestSummaries.Count</div>
            <p class="text-muted mb-0 small">ชุดทดสอบจากมุมมองสรุปผล / Test set from summary view</p>
        </article>
    </div>
    <div class="col-12 col-md-4">
        <article class="content-panel h-100 adj-stat-card">
            <div class="eyebrow">Master Data</div>
            <h2 class="h6 mb-1">Prorate Records</h2>
            <div class="display-6 fw-semibold">@Model.ProrateRecords.Count</div>
            <p class="text-muted mb-0 small">รายการของ channel/period ปัจจุบัน / Records in current channel and period</p>
        </article>
    </div>
</section>

@if (TempData["Message"] is string msg)
{
    var cls = msg.StartsWith("Error") ? "alert-danger" : "alert-success";
    <div class="alert @cls alert-dismissible fade show mb-3" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Filter -->
<div class="content-panel mb-4 adj-shell">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label small fw-semibold">Channel</label>
            <select name="ChannelId" class="form-select form-select-sm" style="min-width:130px;">
                @foreach (var c in Model.Channels)
                {
                    <option value="@c.ChannelId" selected="@(c.ChannelId == Model.ChannelId)">@c.ChannelCode – @c.ChannelNameEn</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label small fw-semibold">Period</label>
            <select name="PeriodId" class="form-select form-select-sm" style="min-width:130px;">
                @foreach (var p in Model.Periods)
                {
                    <option value="@p.PeriodId" selected="@(p.PeriodId == Model.PeriodId)">@p.PeriodCode</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary btn-sm">Load</button>
        </div>
    </form>
    <p class="text-muted small mb-0 mt-2">เลือก Channel และ Period เพื่อโหลดข้อมูลที่ใช้งานจริง / Select channel and period to load operational data.</p>
</div>

<!-- Prorate Rule Reference -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="content-panel">
            <h6 class="fw-semibold mb-3">Prorate Rules (3.2)</h6>
            <p class="text-muted small mb-3">แนวทางอ้างอิงสำหรับการแบ่งสัดส่วนตามวันทำงานจริง / Reference guideline for prorating by actual working days.</p>
            <div class="table-responsive">
                <table class="table table-sm enterprise-table mb-0 small">
                    <thead>
                        <tr>
                            <th>Case</th>
                            <th>Logic</th>
                            <th>Example</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="badge bg-success">JOIN</span> เริ่มงานกลางเดือน / Employee started mid-month</td>
                            <td>Prorate = (วันทำงานจริง / วันทำงานทั้งเดือน) × Incentive เต็มเดือน / Prorate = (Actual working days / Total working days in month) x Full incentive</td>
                            <td>เริ่มวันที่ 16 = คำนวณ 50% / Joined on day 16 = 50%</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-danger">RESIGN</span> ลาออกกลางเดือน / Employee resigned mid-month</td>
                            <td>ต้องระบุนโยบายจ่าย/ไม่จ่าย / Specify pay-or-withhold policy</td>
                            <td>ต้องยืนยันโดย HR / Requires HR confirmation</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-warning text-dark">TRANSFER</span> ย้ายเขตกลางงวด / Cross-region transfer mid-period</td>
                            <td>คำนวณแยกตามแต่ละเขตตามจำนวนวัน / Calculate each region proportionally by days</td>
                            <td>เขต A 10 วัน + เขต B 20 วัน / Region A 10 days + Region B 20 days</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-info text-dark">POSITION_CHANGE</span> เปลี่ยนตำแหน่งกลางงวด / Position change mid-period</td>
                            <td>กำหนดว่าจะใช้อัตราเดิม/ใหม่ หรือแบ่งช่วง / Specify old/new rate or split period</td>
                            <td>ต้องยืนยันโดย HR/Finance / Requires HR/Finance confirmation</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Active Adjustment Formulas (from view) -->
<div class="content-panel mb-4 adj-shell">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-semibold mb-0">Active Adjustment Formulas (vw_active_adjustment_formulas)</h6>
        <span class="badge bg-secondary">@Model.ActiveFormulas.Count formulas</span>
    </div>
    <p class="text-muted small mb-3">อ่านสูตรจากฐานข้อมูลโดยตรง เพื่อให้หน้าจอสอดคล้องกับกฎจริงของระบบ / Reads formulas directly from database so UI follows actual system rules.</p>

    @if (Model.ActiveFormulas.Count == 0)
    {
        <div class="adj-empty-state">
            <span class="text-muted small">No active formulas from vw_active_adjustment_formulas.</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover enterprise-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Order</th>
                        <th>Code</th>
                        <th>Type</th>
                        <th>Name</th>
                        <th>Config</th>
                        <th>Approval</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in Model.ActiveFormulas)
                    {
                        <tr>
                            <td><span class="badge bg-dark">@f.CalcOrderLabel</span></td>
                            <td class="fw-semibold">@f.AdjustmentCode</td>
                            <td>@f.AdjustmentType</td>
                            <td>
                                <div class="fw-semibold">@f.AdjustmentName</div>
                                @if (!string.IsNullOrWhiteSpace(f.Description))
                                {
                                    <div class="small text-muted">@f.Description</div>
                                }
                            </td>
                            <td>
                                @if (f.RequiresConfig)
                                {
                                    <span class="badge bg-warning text-dark">Required (@f.ConfigKey)</span>
                                }
                                else
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </td>
                            <td>
                                @if (f.RequiresApproval)
                                {
                                    <span class="badge bg-info text-dark">Required</span>
                                }
                                else
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- SP Simulation -->
<div class="content-panel mb-4 adj-shell">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-semibold mb-0">SP Simulation (usp_apply_adjustments)</h6>
        <span class="badge bg-primary-subtle text-primary-emphasis">Shortage → Special → Prorate</span>
    </div>
    <p class="text-muted small mb-3">จำลองการคำนวณตามลำดับจริงของ Stored Procedure และแสดง log รายขั้นตอน / Simulate exact stored-procedure order with step-by-step log.</p>

    <form method="post" asp-page-handler="ApplyAdjustments" class="row g-2 align-items-end mb-3">
        <input type="hidden" name="ChannelId" value="@Model.ChannelId" />
        <input type="hidden" name="PeriodId" value="@Model.PeriodId" />

        <div class="col-md-2">
            <label class="form-label small fw-semibold">Base Incentive</label>
            <input class="form-control form-control-sm" type="number" step="0.01" min="0" name="Input.BaseIncentive" value="@Model.Input.BaseIncentive" required />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Actual</label>
            <input class="form-control form-control-sm" type="number" step="0.01" min="0" name="Input.ActualAmount" value="@Model.Input.ActualAmount" required />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Target</label>
            <input class="form-control form-control-sm" type="number" step="0.01" min="0" name="Input.TargetAmount" value="@Model.Input.TargetAmount" required />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Standard 100%</label>
            <input class="form-control form-control-sm" type="number" step="0.01" min="0" name="Input.Standard100Pct" value="@Model.Input.Standard100Pct" required />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Weight (%)</label>
            <input class="form-control form-control-sm" type="number" step="0.01" min="0" max="100" name="Input.AllocationWeightPct" value="@Model.Input.AllocationWeightPct" required />
        </div>
        <div class="col-md-1">
            <label class="form-label small fw-semibold">Work</label>
            <input class="form-control form-control-sm" type="number" min="0" max="31" name="Input.WorkDays" value="@Model.Input.WorkDays" required />
        </div>
        <div class="col-md-1">
            <label class="form-label small fw-semibold">Period</label>
            <input class="form-control form-control-sm" type="number" min="1" max="31" name="Input.PeriodDays" value="@Model.Input.PeriodDays" required />
        </div>

        <div class="col-md-3 form-check mt-2">
            <input class="form-check-input" type="checkbox" name="Input.ShortageConfigEnabled" value="true" checked="@Model.Input.ShortageConfigEnabled" id="shortageEnabled" />
            <input type="hidden" name="Input.ShortageConfigEnabled" value="false" />
            <label class="form-check-label small" for="shortageEnabled">Shortage Config Enabled</label>
        </div>
        <div class="col-md-3 form-check mt-2">
            <input class="form-check-input" type="checkbox" name="Input.SpecialApproved" value="true" checked="@Model.Input.SpecialApproved" id="specialApproved" />
            <input type="hidden" name="Input.SpecialApproved" value="false" />
            <label class="form-check-label small" for="specialApproved">Special Approved</label>
        </div>
        <div class="col-md-2 mt-2">
            <button type="submit" class="btn btn-primary btn-sm">Run SP</button>
        </div>
    </form>

    @if (Model.LastCalcResult is not null)
    {
        <div class="alert alert-info mb-2">
            <strong>Adjusted Incentive:</strong> @Model.LastCalcResult.AdjustedIncentive.ToString("N2")
        </div>
        <pre class="p-2 bg-light border rounded small mb-0" style="white-space: pre-wrap;">@Model.LastCalcResult.AdjustmentLogJson</pre>
    }
</div>

<!-- Test Summary & Run -->
<div class="content-panel mb-4 adj-shell">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-semibold mb-0">Adjustment Test Summary (vw_adjustment_test_summary)</h6>
        <span class="badge bg-secondary">@Model.TestSummaries.Count test cases</span>
    </div>
    <p class="text-muted small mb-3">ผลทดสอบจาก view กลาง และรันทดสอบรายเคสได้ทันที / Test status from central view and run each case on demand.</p>

    @if (Model.TestSummaries.Count == 0)
    {
        <div class="adj-empty-state">
            <span class="text-muted small">No test cases from vw_adjustment_test_summary.</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover enterprise-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Group</th>
                        <th>Case</th>
                        <th>Type</th>
                        <th>Expected</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.TestSummaries)
                    {
                        var statusClass = t.TestStatus switch
                        {
                            "PASS" => "bg-success",
                            "FAIL" => "bg-danger",
                            "SKIP" => "bg-warning text-dark",
                            _ => "bg-secondary"
                        };

                        <tr>
                            <td class="fw-semibold">@t.TestCaseCode</td>
                            <td>@t.TestGroupLabel</td>
                            <td>
                                @t.TestCaseName
                                @if (t.IsEdgeCase)
                                {
                                    <span class="badge bg-dark ms-1">EDGE</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(t.FailReason))
                                {
                                    <div class="small text-danger">@t.FailReason</div>
                                }
                            </td>
                            <td>@t.AdjustmentType</td>
                            <td>
                                @if (t.ExpectedOutput.HasValue)
                                {
                                    @t.ExpectedOutput.Value.ToString("N2")
                                }
                                else
                                {
                                    @t.ExpectedCondition
                                }
                            </td>
                            <td><span class="badge @statusClass">@t.TestStatus</span></td>
                            <td>
                                <form method="post" asp-page-handler="RunTest" class="d-inline">
                                    <input type="hidden" name="ChannelId" value="@Model.ChannelId" />
                                    <input type="hidden" name="PeriodId" value="@Model.PeriodId" />
                                    <input type="hidden" name="TestCaseCode" value="@t.TestCaseCode" />
                                    <button type="submit" class="btn btn-outline-primary btn-sm py-0 px-2">Run</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Existing Records -->
<div class="content-panel mb-4 adj-shell">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-semibold mb-0">Prorate Records — @Model.SelectedChannelCode / @Model.SelectedPeriodCode</h6>
        <span class="badge bg-secondary">@Model.ProrateRecords.Count records</span>
    </div>
    <p class="text-muted small mb-3">ข้อมูลที่บันทึกเพื่อใช้ในรอบคำนวณจริง / Operational records used in real calculation cycle.</p>

    @if (Model.ProrateRecords.Count == 0)
    {
        <div class="adj-empty-state">
            <span class="text-muted small">No prorate records for this channel/period.</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover enterprise-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Name</th>
                        <th>Type</th>
                        <th class="text-center">Actual Days</th>
                        <th class="text-center">Total Days</th>
                        <th class="text-center">Factor</th>
                        <th>Remarks</th>
                        <th>Approved By</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.ProrateRecords)
                    {
                        var badgeClass = r.ProrateType switch {
                            "JOIN"            => "bg-success",
                            "RESIGN"          => "bg-danger",
                            "TRANSFER"        => "bg-warning text-dark",
                            "POSITION_CHANGE" => "bg-info text-dark",
                            _                 => "bg-secondary"
                        };
                        var factor = r.TotalDays > 0 ? (decimal)r.ActualDays / r.TotalDays : 0m;
                        <tr>
                            <td class="fw-semibold">@r.EmployeeCode</td>
                            <td>@r.EmployeeNameTh</td>
                            <td><span class="badge @badgeClass small">@r.ProrateType</span></td>
                            <td class="text-center">@r.ActualDays</td>
                            <td class="text-center">@r.TotalDays</td>
                            <td class="text-center fw-semibold">@factor.ToString("P0")</td>
                            <td class="text-muted small">@r.Remarks</td>
                            <td class="text-muted small">@r.ApprovedBy</td>
                            <td>
                                <form method="post" asp-page-handler="Delete" class="d-inline">
                                    <input type="hidden" name="ProrateId" value="@r.ProrateId" />
                                    <input type="hidden" name="ChannelId" value="@Model.ChannelId" />
                                    <input type="hidden" name="PeriodId" value="@Model.PeriodId" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-1"
                                            onclick="return confirm('Delete prorate record for @r.EmployeeCode?')">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Add New Record Form -->
<div class="content-panel adj-shell">
    <h6 class="fw-semibold mb-3">Add Prorate Record</h6>
    <p class="text-muted small mb-3">เพิ่มรายการปรับวันทำงานเพื่อสะท้อนสถานการณ์จริงของพนักงาน / Add prorate records to reflect real employee movement scenarios.</p>
    <form method="post" asp-page-handler="Save" class="row g-3">
        <input type="hidden" name="ChannelId" value="@Model.ChannelId" />
        <input type="hidden" name="PeriodId" value="@Model.PeriodId" />

        <div class="col-md-3">
            <label class="form-label small fw-semibold">Employee</label>
            <select name="EmployeeCode" class="form-select form-select-sm" required>
                <option value="">-- Select Employee --</option>
                @foreach (var e in Model.Employees)
                {
                    <option value="@e.EmployeeCode">@e.EmployeeCode – @e.EmployeeNameTh</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label small fw-semibold">Type</label>
            <select name="ProrateType" class="form-select form-select-sm" required>
                <option value="JOIN">JOIN – Started mid-month</option>
                <option value="RESIGN">RESIGN – Left mid-month</option>
                <option value="TRANSFER">TRANSFER – Cross-region transfer</option>
                <option value="POSITION_CHANGE">POSITION_CHANGE – Position change</option>
            </select>
        </div>

        <div class="col-md-1">
            <label class="form-label small fw-semibold">Actual Days</label>
            <input type="number" name="ActualDays" class="form-control form-control-sm text-center"
                   min="0" max="31" value="11" required />
        </div>

        <div class="col-md-1">
            <label class="form-label small fw-semibold">Total Days</label>
            <input type="number" name="TotalDays" class="form-control form-control-sm text-center"
                   min="1" max="31" value="22" required />
        </div>

        <div class="col-md-2">
            <label class="form-label small fw-semibold">Approved By</label>
            <input type="text" name="ApprovedBy" class="form-control form-control-sm"
                   placeholder="Approver name" />
        </div>

        <div class="col-md-2">
            <label class="form-label small fw-semibold">Remarks</label>
            <input type="text" name="Remarks" class="form-control form-control-sm"
                   placeholder="Remarks" />
        </div>

        <div class="col-md-1 d-flex align-items-end">
            <button type="submit" class="btn btn-primary btn-sm w-100">Save</button>
        </div>
    </form>

    <div class="adj-note mt-3">
        <strong>Note:</strong> Factor = Actual Days / Total Days
        (เช่น 11/22 = 50% / e.g. 11/22 = 50%). ตัวคูณนี้ใช้กับ incentive เต็มเดือน / This factor multiplies the full-month calculated incentive.
    </div>
</div>
