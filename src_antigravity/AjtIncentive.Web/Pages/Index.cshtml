@page
@model IndexModel
@{
    ViewData["Title"] = Localizer["DashboardTitle"];
    var readyChannels = Model.ChannelSummaries.Count(c => c.HasProcedure && c.ReadyPeriodCount > 0);
}

<section class="hero-banner mb-4 enterprise-hero dashboard-hero leaf-card">
    <div class="row align-items-center g-4">
        <div class="col-xl-8">
            <div class="eyebrow">@Localizer["DashboardTitle"]</div>
            <h1 class="display-6 fw-bold mb-2">AJT Sale Incentive</h1>
            <p class="lead text-muted mb-3">
                @Localizer["DashboardDesc"]
            </p>
            <div class="d-flex flex-wrap gap-2">
                <span class="badge badge-soft-red rounded-full">@Localizer["MasterDataDriven"]</span>
                <span class="badge badge-soft-green rounded-full">@string.Format(Localizer["CalculationReady"].Value, readyChannels)</span>
                <span class="badge badge-soft-gray rounded-full">@Localizer["ForHROutputLinked"]</span>
            </div>
        </div>
        <div class="col-xl-4">
            <div class="hero-stat-card dashboard-hero__card leaf-card">
                <div class="stat-label">@Localizer["OperationalSnapshot"]</div>
                <div class="stat-value">@Model.Snapshot.CalcRunCount Runs</div>
                <div class="stat-sub mb-2">Periods: @Model.Snapshot.PeriodCount / Employees: @Model.Snapshot.ActiveEmployeeCount</div>
                <div class="dashboard-health-line">
                    <span>@Localizer["StoredProcedures"]</span>
                    <strong>@Model.ChannelSummaries.Count(c => c.HasProcedure)/4 Ready</strong>
                </div>
                <div class="dashboard-health-line">
                    <span>@Localizer["ChannelsReady"]</span>
                    <strong>@readyChannels/4</strong>
                </div>
                <!-- Demonstating Currency formatting THB -->
                <div class="dashboard-health-line mt-2 pt-2 border-top">
                    <span>Total Incentive (Demo)</span>
                    <strong class="text-success">@((1500000.50m).ToString("C"))</strong>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="mb-4">
    <div class="row g-3">
        <div class="col-6 col-lg-3">
            <div class="kpi-card leaf-card">
                <div class="kpi-label">@Localizer["MasterPeriods"]</div>
                <div class="kpi-value">@Model.Snapshot.PeriodCount</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="kpi-card leaf-card">
                <div class="kpi-label">@Localizer["ActiveChannels"]</div>
                <div class="kpi-value">@Model.Snapshot.ActiveChannelCount</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="kpi-card leaf-card">
                <div class="kpi-label">@Localizer["LatestMTRun"]</div>
                <div class="kpi-value">@(Model.Snapshot.LatestMtRunId?.ToString() ?? "-")</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="kpi-card leaf-card">
                <div class="kpi-label">@Localizer["LatestTTRun"]</div>
                <div class="kpi-value">@(Model.Snapshot.LatestTtRunId?.ToString() ?? "-")</div>
            </div>
        </div>
    </div>
</section>

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <div class="eyebrow">@Localizer["ChannelOperations"]</div>
            <h2 class="h5 mb-0">@Localizer["CalculationReadiness"]</h2>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var channel in Model.ChannelSummaries)
        {
            var statusClass = channel.HasProcedure && channel.ReadyPeriodCount > 0 ? "ready" : channel.HasProcedure ? "warning" : "blocked";
            var statusText = channel.HasProcedure && channel.ReadyPeriodCount > 0
                ? "Ready to Calculate"
                : channel.HasProcedure
                    ? "SP ready, data incomplete"
                    : "SP not ready";
            var formulaNote = channel.ChannelCode switch
            {
                "MT"   => "Calculated by product group; each salesman covers multiple product groups.",
                "TT"   => "Calculated by SKU; processes all WS Types in one run.",
                "SI"   => "MT-based pattern; used for S&I test channel.",
                "LAOS" => "TT-like pattern with product mapping A/R/B/Y \u2192 AJ/RD/BD/YY.",
                _      => "Derived from database master data."
            };
            <div class="col-12 col-md-6">
                <article class="dashboard-channel-card leaf-card dashboard-channel-card--@statusClass">
                    <div class="dashboard-channel-card__head">
                        <div>
                            <div class="module-kicker mb-1">@channel.ChannelCode</div>
                            <h3 class="h5 mb-1">@channel.ChannelNameEn Calculation</h3>
                            <p class="text-muted mb-0 small">@formulaNote</p>
                        </div>
                        <span class="dashboard-status-pill dashboard-status-pill--@statusClass rounded-full">@statusText</span>
                    </div>

                    <div class="dashboard-channel-grid">
                        <div>
                            <div class="dashboard-mini-label">Latest Ready Period</div>
                            <div class="dashboard-mini-value">@((channel.LatestReadyPeriodCode != string.Empty ? channel.LatestReadyPeriodCode : "-"))</div>
                        </div>
                        <div>
                            <div class="dashboard-mini-label">Latest Calc Run</div>
                            <div class="dashboard-mini-value">@(channel.LatestCalcRunId?.ToString() ?? "-")</div>
                        </div>
                        <div>
                            <div class="dashboard-mini-label">Ready Period Count</div>
                            <div class="dashboard-mini-value">@channel.ReadyPeriodCount</div>
                        </div>
                        <div>
                            <div class="dashboard-mini-label">For HR Rows</div>
                            <div class="dashboard-mini-value">@channel.LatestForHrRowCount</div>
                        </div>
                    </div>

                    <div class="dashboard-channel-actions">
                        <a class="btn btn-sm btn-danger rounded-full" asp-page="/Calculation/Index">Run Calculation</a>
                        <a class="btn btn-sm btn-outline-secondary rounded-full" asp-page="/ForHR/Index">Review For HR</a>
                    </div>
                </article>
            </div>
        }
    </div>
</section>

<section class="mb-4">
    <div class="row g-4">
        <div class="col-12 col-xl-4">
            <div class="content-panel dashboard-process-card leaf-card h-100">
                <div class="eyebrow">@Localizer["Step1"]</div>
                <h2 class="h5">@Localizer["MasterSetup"]</h2>
                <div class="dashboard-process-links mt-3">
                    <a class="module-card dashboard-mini-card leaf-card" asp-page="/Periods/Index">
                        <h3>Periods</h3>
                    </a>
                    <a class="module-card dashboard-mini-card leaf-card" asp-page="/Parameters/Index">
                        <h3>Parameters</h3>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-4">
            <div class="content-panel dashboard-process-card leaf-card h-100">
                <div class="eyebrow">@Localizer["Step2"]</div>
                <h2 class="h5">@Localizer["CalcAdjust"]</h2>
                <div class="dashboard-process-links mt-3">
                    <a class="module-card dashboard-mini-card leaf-card" asp-page="/Calculation/Index">
                        <h3>Calculation</h3>
                    </a>
                    <a class="module-card dashboard-mini-card leaf-card" asp-page="/Prorate/Index">
                        <h3>Adjustments</h3>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-4">
            <div class="content-panel dashboard-process-card leaf-card h-100">
                <div class="eyebrow">@Localizer["Step3"]</div>
                <h2 class="h5">@Localizer["ReviewOutput"]</h2>
                <div class="dashboard-process-links mt-3">
                    <a class="module-card dashboard-mini-card leaf-card" asp-page="/ForHR/Index">
                        <h3>For HR</h3>
                    </a>
                    <a class="module-card dashboard-mini-card leaf-card" asp-page="/Approvals/Index">
                        <h3>Approvals</h3>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-xl-7">
        <div class="content-panel leaf-card h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <div class="eyebrow">@Localizer["RecentProcessRuns"]</div>
                    <h2 class="h5 mb-0">@Localizer["LatestCalcRuns"]</h2>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-borderless align-middle enterprise-table">
                    <thead>
                        <tr>
                            <th>Run</th>
                            <th>Channel</th>
                            <th>Period</th>
                            <th>Status</th>
                            <th>Updated</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var run in Model.RecentRuns)
                    {
                        <tr>
                            <td class="fw-semibold">@run.CalcRunId</td>
                            <td>@run.ChannelCode</td>
                            <td>@run.PeriodCode</td>
                            <td><span class="badge rounded-pill bg-light text-dark border">@run.RunStatus</span></td>
                            <td>@(run.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-xl-5">
        <div class="content-panel leaf-card h-100">
            <div class="eyebrow">@Localizer["SystemReadiness"]</div>
            <h2 class="h5">@Localizer["CapabilityChecks"]</h2>
            <ul class="list-unstyled mb-0 mt-3 dashboard-checklist">
                <li>MT SP: <strong>@(Model.Snapshot.HasMtSp ? "Ready" : "Missing")</strong></li>
                <li>TT SP: <strong>@(Model.Snapshot.HasTtSp ? "Ready" : "Missing")</strong></li>
                <li>S&I SP: <strong>@(Model.Snapshot.HasSiSp ? "Ready" : "Missing")</strong></li>
                <li>Laos SP: <strong>@(Model.Snapshot.HasLaosSp ? "Ready" : "Missing")</strong></li>
            </ul>
        </div>
    </div>
</div>
