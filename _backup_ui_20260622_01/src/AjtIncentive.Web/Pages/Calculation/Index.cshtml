@page
@model AjtIncentive.Web.Pages.Calculation.IndexModel
@{
    ViewData["Title"] = "Calculation";
}

<div class="container mt-4">
    <h2>Run Incentive Calculation</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">MT Calculation</div>
                <div class="card-body">
                    <p class="card-text">Run incentive calculation for Modern Trade channel.</p>
                    <form method="post" asp-page-handler="RunMt">
                        <div class="mb-3">
                            <label for="periodId" class="form-label">Period ID</label>
                            <input type="number" class="form-control" id="periodId" name="periodId" value="1" required>
                        </div>
                        <button type="submit" class="btn btn-primary">Run MT</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header bg-success text-white">TT Calculation</div>
                <div class="card-body">
                    <p class="card-text">Run incentive calculation for Traditional Trade channel.</p>
                    <form method="post" asp-page-handler="RunTt">
                        <div class="mb-3">
                            <label for="ttPeriodId" class="form-label">Period ID</label>
                            <input type="number" class="form-control" id="ttPeriodId" name="periodId" value="1" required>
                        </div>
                        <button type="submit" class="btn btn-success">Run TT</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info mt-3">
            @TempData["Message"]
        </div>
    }
</div>
