@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="hero-banner mb-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-8">
            <div class="eyebrow">Leading in creation of Well-Being</div>
            <h1 class="display-5 fw-semibold mb-3">Dashboard สำหรับ Demo POC</h1>
            <p class="lead text-muted mb-0">
                เข้าถึงการคำนวณ Incentive, ตรวจ Period, ดู For HR และจัดการ Parameters / Approvals ได้จากเมนูหลักด้านบน
            </p>
            <div class="hero-badges mt-4 d-flex flex-wrap gap-2">
                <span class="badge rounded-pill text-bg-danger px-3 py-2">Modern Trade</span>
                <span class="badge rounded-pill text-bg-success px-3 py-2">Traditional Trade</span>
                <span class="badge rounded-pill text-bg-light text-dark border px-3 py-2">Demo POC</span>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="hero-stat-card hero-stat-card--accent">
                <div class="stat-label">Current Stack</div>
                <div class="stat-value">.NET 10 + Razor Pages</div>
                <div class="stat-sub">EF Core 10 · Dapper · SQL Server</div>
            </div>
        </div>
    </div>
</section>

<section class="story-banner mb-4">
    <div class="row g-3">
        <div class="col-md-4">
            <div class="story-card story-card--red">
                <div class="story-label">Quick Run</div>
                <h2 class="h5 mb-2">Calculation</h2>
                <p class="mb-0">รัน MT / TT incentive calculation และตรวจผลลัพธ์ล่าสุด</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="story-card story-card--green">
                <div class="story-label">Export</div>
                <h2 class="h5 mb-2">For HR</h2>
                <p class="mb-0">ดูผลสรุปสำหรับส่งต่อฝ่าย HR และตรวจยอดรายคน</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="story-card story-card--sand">
                <div class="story-label">Setup</div>
                <h2 class="h5 mb-2">Periods</h2>
                <p class="mb-0">จัดการ period และรอบคำนวณของแต่ละ channel</p>
            </div>
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-md-6 col-xl-4">
        <a class="module-card" asp-page="/Calculation/Index">
            <div class="module-kicker">Run</div>
            <h2>Calculation</h2>
            <p>รัน MT / TT incentive calculation และตรวจผลลัพธ์ล่าสุด</p>
        </a>
    </div>
    <div class="col-md-6 col-xl-4">
        <a class="module-card" asp-page="/Periods/Index">
            <div class="module-kicker">Setup</div>
            <h2>Periods</h2>
            <p>จัดการ Period ที่ใช้สำหรับการคำนวณแต่ละรอบ</p>
        </a>
    </div>
    <div class="col-md-6 col-xl-4">
        <a class="module-card" asp-page="/ForHR/Index">
            <div class="module-kicker">Export</div>
            <h2>For HR</h2>
            <p>ดูผลสรุปสำหรับส่งต่อฝ่าย HR และตรวจยอดรายคน</p>
        </a>
    </div>
    <div class="col-md-6 col-xl-4">
        <a class="module-card" asp-page="/Parameters/Index">
            <div class="module-kicker">Config</div>
            <h2>Parameters</h2>
            <p>ปรับ threshold, rate, weight และ business parameters</p>
        </a>
    </div>
    <div class="col-md-6 col-xl-4">
        <a class="module-card" asp-page="/Approvals/Index">
            <div class="module-kicker">Workflow</div>
            <h2>Approvals</h2>
            <p>ตรวจสถานะอนุมัติและติดตาม action ที่ค้างอยู่</p>
        </a>
    </div>
</div>
